<!--pages/study/study.wxml-->
<view class="container">
  <!-- 进度指示器 -->
  <view class="progress-indicator">
    <text>{{currentIndex + 1}} / {{totalWords}}</text>
  </view>

  <!-- 实词卡片 -->
  <view class="word-card card" wx:if="{{currentWord}}">
    <!-- 实词标题 -->
    <view class="word-header">
      <view class="word-title">{{currentWord.word}}</view>
      <view class="word-pinyin">{{currentWord.pinyin}}</view>
      <view class="word-category">{{currentWord.category}}</view>
    </view>

    <!-- 义项列表 -->
    <view class="meanings-section" wx:if="{{showAnswer}}">
      <view class="meaning-item" wx:for="{{currentWord.meanings}}" wx:key="index">
        <view class="meaning-num">{{index + 1}}.</view>
        <view class="meaning-content">
          <view class="meaning-text">{{item.meaning}}</view>
          <view class="meaning-example">例：{{item.example}}</view>
        </view>
      </view>
    </view>

    <!-- 提示信息 -->
    <view class="hint-section" wx:if="{{!showAnswer}}">
      <text class="hint-text">请回忆这个实词的含义和用法</text>
    </view>

    <!-- 操作按钮 -->
    <view class="action-buttons">
      <view class="btn-secondary" wx:if="{{!showAnswer}}" bindtap="showAnswerTap">
        查看答案
      </view>

      <view class="answer-buttons" wx:if="{{showAnswer}}">
        <view class="btn-error" bindtap="answerWrong">
          ✗ 不会
        </view>
        <view class="btn-success" bindtap="answerCorrect">
          ✓ 掌握
        </view>
      </view>
    </view>

    <!-- 收藏按钮 -->
    <view class="collect-btn {{isCollected ? 'collected' : ''}}" bindtap="toggleCollect">
      <text>{{isCollected ? '★' : '☆'}} {{isCollected ? '已收藏' : '收藏'}}</text>
    </view>
  </view>

  <!-- 完成提示 -->
  <view class="complete-card card" wx:if="{{isComplete}}">
    <view class="complete-icon">✓</view>
    <view class="complete-title">学习完成！</view>
    <view class="complete-stats">
      <view class="stat-row">
        <text>正确：</text>
        <text class="text-success">{{correctCount}}</text>
      </view>
      <view class="stat-row">
        <text>错误：</text>
        <text class="text-error">{{wrongCount}}</text>
      </view>
      <view class="stat-row">
        <text>正确率：</text>
        <text class="text-primary">{{accuracy}}%</text>
      </view>
    </view>
    <view class="btn-primary" bindtap="backToHome">
      返回首页
    </view>
    <view class="btn-secondary" bindtap="studyAgain">
      再来一轮
    </view>
  </view>
</view>
