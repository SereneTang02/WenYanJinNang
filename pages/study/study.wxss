/* pages/study/study.wxss - 温润古典·书卷风 */
page {
  background: #FBF6F0;
}

.container {
  padding: 0 0 40rpx;
}

/* ===== 顶部栏 ===== */
.hero-card {
  background: linear-gradient(180deg, #E8D5B8 0%, #F2E8D6 60%, #FBF6F0 100%);
  padding: 50rpx 36rpx 36rpx;
  color: #1A1008;
  border-radius: 0 0 48rpx 48rpx;
  margin-bottom: 30rpx;
  text-align: center;
  position: relative;
  overflow: hidden;
}

.hero-card::after {
  content: '';
  position: absolute;
  top: -60rpx;
  right: -60rpx;
  width: 240rpx;
  height: 240rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(200, 168, 124, 0.12) 0%, transparent 70%);
}

.hero-title {
  font-size: 40rpx;
  font-weight: bold;
  margin-bottom: 8rpx;
  color: #1A1008;
}

.hero-sub {
  font-size: 28rpx;
  color: #4A3C30;
  opacity: 1;
  margin-bottom: 16rpx;
}

.progress-bar-bg {
  height: 10rpx;
  background: rgba(200, 175, 140, 0.2);
  border-radius: 5rpx;
  overflow: hidden;
}

.progress-bar-fill {
  height: 100%;
  background: linear-gradient(90deg, #C4882E, #E8C36A);
  border-radius: 5rpx;
  transition: width 0.3s ease;
}

/* ===== 词卡片 ===== */
.word-card {
  background: rgba(255, 255, 255, 0.88);
  border: 1rpx solid rgba(200, 175, 140, 0.18);
  border-radius: 24rpx;
  padding: 36rpx 30rpx;
  margin: 0 24rpx 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(166, 138, 100, 0.08);
  position: relative;
  backdrop-filter: blur(10rpx);
}

/* 任务类型标签 */
.task-tag {
  position: absolute;
  top: 0;
  right: 30rpx;
  padding: 8rpx 20rpx;
  border-radius: 0 0 14rpx 14rpx;
  font-size: 22rpx;
  font-weight: bold;
  color: #fff;
}

.tag-current {
  background: linear-gradient(135deg, #3A8FC2, #89B4D4);
}

.tag-review {
  background: linear-gradient(135deg, #4CAF50, #96C88A);
}

.tag-preview {
  background: linear-gradient(135deg, #C4882E, #E8C36A);
}

/* 词头 */
.word-header {
  text-align: center;
  padding-bottom: 30rpx;
  border-bottom: 2rpx solid rgba(200, 175, 140, 0.18);
}

.word-title {
  font-size: 72rpx;
  font-weight: bold;
  color: #1A1008;
  margin-bottom: 12rpx;
}

.word-pinyin {
  font-size: 32rpx;
  color: #4A3C30;
  margin-bottom: 12rpx;
}

.word-category-tag {
  display: inline-block;
  padding: 8rpx 24rpx;
  background: rgba(200, 168, 124, 0.12);
  color: #9E6B2C;
  border: 2rpx solid #C9B18A;
  border-radius: 20rpx;
  font-size: 24rpx;
}

/* 提示区域 */
.hint-section {
  padding: 80rpx 0;
  text-align: center;
}

.hint-text {
  font-size: 28rpx;
  color: #5C4D3E;
  margin-bottom: 40rpx;
  display: block;
}

.flip-btn {
  display: inline-block;
  padding: 22rpx 80rpx;
  background: linear-gradient(135deg, #C4882E, #9E6B2C);
  color: #fff;
  border-radius: 44rpx;
  font-size: 32rpx;
  font-weight: bold;
  box-shadow: 0 8rpx 24rpx rgba(166, 138, 100, 0.25);
}

.flip-btn:active {
  opacity: 0.85;
  transform: scale(0.98);
}

/* 义项区域 */
.meanings-section {
  padding-top: 24rpx;
}

.meaning-item {
  display: flex;
  gap: 12rpx;
  margin-bottom: 28rpx;
}

.meaning-num {
  font-size: 28rpx;
  color: #C4882E;
  font-weight: bold;
  flex-shrink: 0;
}

.meaning-content {
  flex: 1;
}

.meaning-gloss {
  font-size: 32rpx;
  color: #1A1008;
  font-weight: 500;
  margin-bottom: 8rpx;
}

.meaning-note {
  font-size: 24rpx;
  color: #C4882E;
  margin-bottom: 8rpx;
}

.meaning-example {
  font-size: 26rpx;
  color: #4A3C30;
  line-height: 1.6;
  padding: 12rpx 16rpx;
  background: rgba(200, 168, 124, 0.08);
  border-radius: 12rpx;
  margin-bottom: 8rpx;
  border-left: 4rpx solid rgba(200, 168, 124, 0.3);
}

.example-source {
  color: #5C4D3E;
  font-size: 24rpx;
}

/* 掌握/不会 按钮 */
.answer-buttons {
  display: flex;
  gap: 24rpx;
  margin-top: 32rpx;
}

.ans-btn {
  flex: 1;
  height: 92rpx;
  line-height: 92rpx;
  text-align: center;
  border-radius: 46rpx;
  font-size: 32rpx;
  font-weight: bold;
  color: #fff;
}

.btn-wrong {
  background: linear-gradient(135deg, #E05A47, #D98A7E);
  box-shadow: 0 6rpx 20rpx rgba(201, 107, 92, 0.25);
}

.btn-right {
  background: linear-gradient(135deg, #4CAF50, #96C88A);
  box-shadow: 0 6rpx 20rpx rgba(123, 175, 110, 0.25);
}

.ans-btn:active {
  opacity: 0.85;
  transform: scale(0.98);
}

/* 收藏 */
.collect-row {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 24rpx;
  padding: 12rpx 0;
}

.collect-icon {
  font-size: 36rpx;
  color: #C4882E;
  margin-right: 8rpx;
}

.collect-text {
  font-size: 26rpx;
  color: #5C4D3E;
}

/* ===== 完成卡片 ===== */
.complete-card {
  background: rgba(255, 255, 255, 0.88);
  border: 1rpx solid rgba(200, 175, 140, 0.18);
  border-radius: 24rpx;
  padding: 60rpx 36rpx;
  margin: 0 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(166, 138, 100, 0.08);
  text-align: center;
  backdrop-filter: blur(10rpx);
}

.complete-icon-wrap {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #4CAF50, #96C88A);
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(123, 175, 110, 0.25);
}

.complete-check {
  font-size: 60rpx;
  color: #fff;
  font-weight: bold;
}

.complete-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #1A1008;
  margin-bottom: 32rpx;
}

.complete-stats {
  background: rgba(200, 168, 124, 0.08);
  border-radius: 20rpx;
  padding: 24rpx 30rpx;
  margin-bottom: 36rpx;
  border: 1rpx solid rgba(200, 175, 140, 0.12);
}

.stat-row {
  display: flex;
  justify-content: space-between;
  font-size: 30rpx;
  padding: 12rpx 0;
}

.stat-key {
  color: #4A3C30;
}

.stat-val {
  font-weight: bold;
}

.color-green { color: #4CAF50; }
.color-red { color: #E05A47; }
.color-blue { color: #3A8FC2; }

.complete-actions {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.action-btn {
  width: 100%;
  height: 92rpx;
  line-height: 92rpx;
  border-radius: 46rpx;
  font-size: 32rpx;
  font-weight: bold;
  border: none;
  text-align: center;
  padding: 0;
}

.action-btn::after {
  border: none;
}

.btn-primary-action {
  background: linear-gradient(135deg, #C4882E, #9E6B2C);
  color: #fff;
  box-shadow: 0 8rpx 24rpx rgba(166, 138, 100, 0.25);
}

.btn-secondary-action {
  background: rgba(255, 255, 255, 0.88);
  color: #9E6B2C;
  border: 2rpx solid #C9B18A;
}
