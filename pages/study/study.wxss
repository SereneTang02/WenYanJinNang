/* pages/study/study.wxss */
page {
  background: #f0f2f5;
}

.container {
  padding: 0 0 40rpx;
}

/* ===== 顶部栏 ===== */
.hero-card {
  background: linear-gradient(160deg, #4A90E2 0%, #357ABD 50%, #2E6BA6 100%);
  padding: 50rpx 36rpx 36rpx;
  color: #fff;
  border-radius: 0 0 48rpx 48rpx;
  margin-bottom: 30rpx;
  text-align: center;
  position: relative;
  overflow: hidden;
}

.hero-card::after {
  content: '';
  position: absolute;
  top: -60rpx;
  right: -60rpx;
  width: 240rpx;
  height: 240rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.06);
}

.hero-title {
  font-size: 40rpx;
  font-weight: bold;
  margin-bottom: 8rpx;
}

.hero-sub {
  font-size: 28rpx;
  opacity: 0.8;
  margin-bottom: 16rpx;
}

.progress-bar-bg {
  height: 8rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 4rpx;
  overflow: hidden;
}

.progress-bar-fill {
  height: 100%;
  background: #fff;
  border-radius: 4rpx;
  transition: width 0.3s ease;
}

/* ===== 词卡片 ===== */
.word-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 36rpx 30rpx;
  margin: 0 24rpx 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
  position: relative;
}

/* 任务类型标签 */
.task-tag {
  position: absolute;
  top: 0;
  right: 30rpx;
  padding: 8rpx 20rpx;
  border-radius: 0 0 12rpx 12rpx;
  font-size: 22rpx;
  font-weight: bold;
  color: #fff;
}

.tag-current {
  background: #4A90E2;
}

.tag-review {
  background: #52c41a;
}

.tag-preview {
  background: #fa8c16;
}

/* 词头 */
.word-header {
  text-align: center;
  padding-bottom: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.word-title {
  font-size: 72rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 12rpx;
}

.word-pinyin {
  font-size: 32rpx;
  color: #666;
  margin-bottom: 12rpx;
}

.word-category-tag {
  display: inline-block;
  padding: 6rpx 20rpx;
  background: #4A90E2;
  color: #fff;
  border-radius: 16rpx;
  font-size: 24rpx;
}

/* 提示区域 */
.hint-section {
  padding: 80rpx 0;
  text-align: center;
}

.hint-text {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 40rpx;
  display: block;
}

.flip-btn {
  display: inline-block;
  padding: 20rpx 80rpx;
  background: linear-gradient(135deg, #4A90E2, #357ABD);
  color: #fff;
  border-radius: 40rpx;
  font-size: 32rpx;
  font-weight: bold;
  box-shadow: 0 6rpx 20rpx rgba(74, 144, 226, 0.3);
}

.flip-btn:active {
  opacity: 0.85;
}

/* 义项区域 */
.meanings-section {
  padding-top: 24rpx;
}

.meaning-item {
  display: flex;
  gap: 12rpx;
  margin-bottom: 28rpx;
}

.meaning-num {
  font-size: 28rpx;
  color: #4A90E2;
  font-weight: bold;
  flex-shrink: 0;
}

.meaning-content {
  flex: 1;
}

.meaning-gloss {
  font-size: 32rpx;
  color: #333;
  font-weight: 500;
  margin-bottom: 8rpx;
}

.meaning-note {
  font-size: 24rpx;
  color: #fa8c16;
  margin-bottom: 8rpx;
}

.meaning-example {
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
  padding: 10rpx 14rpx;
  background: #f6f7f9;
  border-radius: 10rpx;
  margin-bottom: 8rpx;
}

.example-source {
  color: #999;
  font-size: 24rpx;
}

/* 掌握/不会 按钮 */
.answer-buttons {
  display: flex;
  gap: 24rpx;
  margin-top: 32rpx;
}

.ans-btn {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  border-radius: 44rpx;
  font-size: 32rpx;
  font-weight: bold;
  color: #fff;
}

.btn-wrong {
  background: linear-gradient(135deg, #ff7875, #f5222d);
  box-shadow: 0 6rpx 16rpx rgba(245, 34, 45, 0.25);
}

.btn-right {
  background: linear-gradient(135deg, #73d13d, #52c41a);
  box-shadow: 0 6rpx 16rpx rgba(82, 196, 26, 0.25);
}

.ans-btn:active {
  opacity: 0.85;
}

/* 收藏 */
.collect-row {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 24rpx;
  padding: 12rpx 0;
}

.collect-icon {
  font-size: 36rpx;
  color: #ffd666;
  margin-right: 8rpx;
}

.collect-text {
  font-size: 26rpx;
  color: #999;
}

/* ===== 完成卡片 ===== */
.complete-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 60rpx 36rpx;
  margin: 0 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
  text-align: center;
}

.complete-icon-wrap {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #73d13d, #52c41a);
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 24rpx;
}

.complete-check {
  font-size: 60rpx;
  color: #fff;
  font-weight: bold;
}

.complete-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 32rpx;
}

.complete-stats {
  background: #f6f7f9;
  border-radius: 16rpx;
  padding: 24rpx 30rpx;
  margin-bottom: 36rpx;
}

.stat-row {
  display: flex;
  justify-content: space-between;
  font-size: 30rpx;
  padding: 12rpx 0;
}

.stat-key {
  color: #666;
}

.stat-val {
  font-weight: bold;
}

.color-green { color: #52c41a; }
.color-red { color: #f5222d; }
.color-blue { color: #4A90E2; }

.complete-actions {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.action-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 44rpx;
  font-size: 32rpx;
  font-weight: bold;
  border: none;
  text-align: center;
  padding: 0;
}

.action-btn::after {
  border: none;
}

.btn-primary-action {
  background: linear-gradient(135deg, #4A90E2, #357ABD);
  color: #fff;
  box-shadow: 0 6rpx 20rpx rgba(74, 144, 226, 0.3);
}

.btn-secondary-action {
  background: #fff;
  color: #4A90E2;
  border: 2rpx solid #4A90E2;
}
