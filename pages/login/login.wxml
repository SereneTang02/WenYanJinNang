<!--pages/login/login.wxml-->
<view class="container">
  <!-- 顶部装饰 -->
  <view class="header-decoration">
    <view class="circle circle-1"></view>
    <view class="circle circle-2"></view>
    <view class="circle circle-3"></view>
  </view>

  <!-- Logo区域 -->
  <view class="logo-section">
    <view class="logo-icon">📖</view>
    <view class="app-name">古文实词背诵</view>
    <view class="app-slogan">轻松掌握120个常用实词</view>
  </view>

  <!-- 特色功能介绍 -->
  <view class="features">
    <view class="feature-item">
      <view class="feature-icon">✨</view>
      <view class="feature-text">智能出题</view>
    </view>
    <view class="feature-item">
      <view class="feature-icon">📊</view>
      <view class="feature-text">学习统计</view>
    </view>
    <view class="feature-item">
      <view class="feature-icon">🎯</view>
      <view class="feature-text">错题本</view>
    </view>
    <view class="feature-item">
      <view class="feature-icon">🏆</view>
      <view class="feature-text">班级PK</view>
    </view>
  </view>

  <!-- 登录按钮 -->
  <view class="login-section">
    <button
      class="login-button {{loading ? 'loading' : ''}}"
      bindtap="onWechatLogin"
      disabled="{{loading}}"
    >
      <view class="button-content">
        <view class="wechat-icon" wx:if="{{!loading}}">🔐</view>
        <text class="button-text">{{loading ? '登录中...' : '微信快捷登录'}}</text>
      </view>
    </button>

    <!-- 用户协议 -->
    <view class="agreement">
      <text class="agreement-text">登录即表示同意</text>
      <text class="agreement-link" bindtap="onViewAgreement">《用户协议》</text>
    </view>
  </view>

  <!-- 底部装饰 -->
  <view class="footer">
    <view class="footer-text">开启古文学习之旅</view>
  </view>
</view>
