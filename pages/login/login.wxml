<!--pages/login/login.wxml-->
<view class="container">
  <!-- 山水画背景 -->
  <image class="bg-painting" src="/image/山水画背景.png" mode="aspectFill" />
  <view class="bg-painting-mask"></view>

  <!-- Logo 区域 -->
  <view class="logo-section">
    <!-- 动画书本图标 -->
    <view class="logo-anim">
      <view class="book">
        <view class="book-left"></view>
        <view class="book-right"></view>
        <view class="book-spine"></view>
      </view>
      <view class="logo-glow"></view>
    </view>
    <view class="app-name">古文实词背诵</view>
    <view class="app-slogan">轻松掌握150个常用实词</view>
  </view>

  <!-- 特色功能 - 动画图标 -->
  <view class="features">
    <!-- 智能出题：灯泡 + 闪烁光芒 -->
    <view class="feature-item">
      <view class="feat-icon feat-bulb">
        <view class="bulb-body"></view>
        <view class="bulb-base"></view>
        <view class="bulb-ray ray-1"></view>
        <view class="bulb-ray ray-2"></view>
        <view class="bulb-ray ray-3"></view>
      </view>
      <view class="feature-label">智能出题</view>
    </view>

    <!-- 学习统计：柱状图 + 增长动画 -->
    <view class="feature-item">
      <view class="feat-icon feat-chart">
        <view class="chart-bar bar-1"></view>
        <view class="chart-bar bar-2"></view>
        <view class="chart-bar bar-3"></view>
        <view class="chart-base-line"></view>
      </view>
      <view class="feature-label">学习统计</view>
    </view>

    <!-- 错题本：笔记本 + 翻页 -->
    <view class="feature-item">
      <view class="feat-icon feat-note">
        <view class="note-body">
          <view class="note-line"></view>
          <view class="note-line"></view>
          <view class="note-line"></view>
        </view>
        <view class="note-corner"></view>
        <view class="note-mark"></view>
      </view>
      <view class="feature-label">错题本</view>
    </view>

    <!-- 班级PK：奖杯 + 闪光 -->
    <view class="feature-item">
      <view class="feat-icon feat-trophy">
        <view class="trophy-cup"></view>
        <view class="trophy-stem"></view>
        <view class="trophy-base"></view>
        <view class="trophy-star"></view>
      </view>
      <view class="feature-label">班级PK</view>
    </view>
  </view>

  <!-- 登录按钮 -->
  <view class="login-section">
    <button class="login-btn {{loading ? 'disabled' : ''}}" bindtap="onWechatLogin" disabled="{{loading}}">
      <text class="login-btn-text">{{loading ? '登录中...' : '微信快捷登录'}}</text>
    </button>

    <view class="agreement">
      <text class="agreement-text">登录即表示同意</text>
      <text class="agreement-link" bindtap="onViewAgreement">《用户协议》</text>
    </view>
  </view>

  <view class="footer">
    <text class="footer-text">开启古文学习之旅</text>
  </view>
</view>
