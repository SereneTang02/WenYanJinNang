/* pages/login/login.wxss */
page {
  background: #4c51bf;
}

.container {
  min-height: 100vh;
  background: linear-gradient(160deg, #667eea 0%, #5a67d8 40%, #4c51bf 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 40rpx 60rpx;
  position: relative;
  overflow: hidden;
}

/* ===== 背景装饰（浮动动画） ===== */
.bg-circle {
  position: absolute;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.05);
}

.bg-circle-1 {
  width: 360rpx;
  height: 360rpx;
  top: -120rpx;
  left: -100rpx;
  animation: floatSlow 8s ease-in-out infinite;
}

.bg-circle-2 {
  width: 200rpx;
  height: 200rpx;
  top: 160rpx;
  right: -50rpx;
  animation: floatSlow 6s ease-in-out infinite 1s;
}

.bg-circle-3 {
  width: 140rpx;
  height: 140rpx;
  bottom: 240rpx;
  left: 40rpx;
  animation: floatSlow 7s ease-in-out infinite 2s;
}

@keyframes floatSlow {
  0%, 100% { transform: translateY(0) scale(1); }
  50% { transform: translateY(-30rpx) scale(1.05); }
}

/* ===== Logo 动画书本 ===== */
.logo-section {
  text-align: center;
  z-index: 1;
  margin-bottom: 60rpx;
}

.logo-anim {
  position: relative;
  width: 180rpx;
  height: 180rpx;
  margin: 0 auto 30rpx;
  animation: logoFloat 3s ease-in-out infinite;
}

@keyframes logoFloat {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-16rpx); }
}

/* 书本 */
.book {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 80rpx;
  height: 96rpx;
}

.book-left {
  position: absolute;
  left: 0;
  top: 0;
  width: 38rpx;
  height: 90rpx;
  background: #fff;
  border-radius: 6rpx 0 0 6rpx;
  transform: skewY(-3deg);
  opacity: 0.95;
}

.book-right {
  position: absolute;
  right: 0;
  top: 0;
  width: 38rpx;
  height: 90rpx;
  background: rgba(255, 255, 255, 0.8);
  border-radius: 0 6rpx 6rpx 0;
  transform: skewY(3deg);
  animation: pageFlip 3s ease-in-out infinite;
}

@keyframes pageFlip {
  0%, 100% { transform: skewY(3deg); }
  50% { transform: skewY(6deg) rotateY(-8deg); }
}

.book-spine {
  position: absolute;
  left: 50%;
  top: -4rpx;
  width: 6rpx;
  height: 98rpx;
  background: rgba(255, 255, 255, 0.5);
  transform: translateX(-50%);
  border-radius: 3rpx;
}

/* 光晕 */
.logo-glow {
  position: absolute;
  top: 50%;
  left: 50%;
  width: 160rpx;
  height: 160rpx;
  transform: translate(-50%, -50%);
  border-radius: 50%;
  border: 3rpx solid rgba(255, 255, 255, 0.2);
  animation: glowPulse 2.5s ease-in-out infinite;
}

@keyframes glowPulse {
  0%, 100% {
    box-shadow: 0 0 20rpx rgba(255, 255, 255, 0.1);
    transform: translate(-50%, -50%) scale(1);
  }
  50% {
    box-shadow: 0 0 40rpx rgba(255, 255, 255, 0.25);
    transform: translate(-50%, -50%) scale(1.06);
  }
}

.app-name {
  font-size: 48rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 14rpx;
  letter-spacing: 4rpx;
}

.app-slogan {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.75);
}

/* ========================================
   特色功能图标 — 纯 CSS 动画图形
   ======================================== */
.features {
  display: flex;
  justify-content: space-around;
  width: 100%;
  z-index: 1;
  margin-bottom: 60rpx;
}

.feature-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.feature-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-top: 14rpx;
}

.feat-icon {
  width: 88rpx;
  height: 88rpx;
  border-radius: 22rpx;
  background: rgba(255, 255, 255, 0.12);
  position: relative;
  overflow: hidden;
}

/* --- 1. 灯泡（智能出题）--- */
.feat-bulb {
  animation: bulbGlow 2.5s ease-in-out infinite;
}

@keyframes bulbGlow {
  0%, 100% { background: rgba(255, 255, 255, 0.12); }
  50% { background: rgba(255, 235, 120, 0.2); }
}

.bulb-body {
  position: absolute;
  top: 18rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 32rpx;
  height: 36rpx;
  border-radius: 50% 50% 8rpx 8rpx;
  background: #ffd966;
  box-shadow: 0 0 16rpx rgba(255, 217, 102, 0.6);
}

.bulb-base {
  position: absolute;
  top: 54rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 22rpx;
  height: 10rpx;
  border-radius: 0 0 4rpx 4rpx;
  background: rgba(255, 255, 255, 0.7);
}

.bulb-ray {
  position: absolute;
  background: rgba(255, 217, 102, 0.7);
  border-radius: 2rpx;
  animation: rayBlink 2s ease-in-out infinite;
}

.ray-1 {
  width: 12rpx;
  height: 3rpx;
  top: 28rpx;
  left: 12rpx;
  transform: rotate(-30deg);
  animation-delay: 0s;
}

.ray-2 {
  width: 12rpx;
  height: 3rpx;
  top: 16rpx;
  left: 50%;
  transform: translateX(-50%);
  animation-delay: 0.4s;
}

.ray-3 {
  width: 12rpx;
  height: 3rpx;
  top: 28rpx;
  right: 12rpx;
  transform: rotate(30deg);
  animation-delay: 0.8s;
}

@keyframes rayBlink {
  0%, 100% { opacity: 0.4; transform: scale(0.8); }
  50% { opacity: 1; transform: scale(1.2); }
}

/* --- 2. 柱状图（学习统计）--- */
.feat-chart {
  display: flex;
  align-items: flex-end;
  justify-content: center;
  padding: 0 16rpx 14rpx;
  gap: 8rpx;
}

.chart-bar {
  width: 14rpx;
  border-radius: 4rpx 4rpx 0 0;
  background: #7dd3fc;
  animation: barGrow 2s ease-in-out infinite;
}

.bar-1 {
  height: 28rpx;
  background: rgba(255, 255, 255, 0.5);
  animation-delay: 0s;
}

.bar-2 {
  height: 42rpx;
  background: rgba(255, 255, 255, 0.7);
  animation-delay: 0.3s;
}

.bar-3 {
  height: 54rpx;
  background: #fff;
  animation-delay: 0.6s;
}

.chart-base-line {
  position: absolute;
  bottom: 16rpx;
  left: 14rpx;
  right: 14rpx;
  height: 2rpx;
  background: rgba(255, 255, 255, 0.3);
}

@keyframes barGrow {
  0%, 100% { transform: scaleY(1); }
  50% { transform: scaleY(0.6); }
}

/* --- 3. 笔记本（错题本）--- */
.feat-note {
  animation: noteWobble 3s ease-in-out infinite;
}

@keyframes noteWobble {
  0%, 100% { transform: rotate(0deg); }
  25% { transform: rotate(2deg); }
  75% { transform: rotate(-2deg); }
}

.note-body {
  position: absolute;
  top: 16rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 48rpx;
  height: 54rpx;
  background: #fff;
  border-radius: 4rpx 10rpx 10rpx 4rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 8rpx;
  padding: 0 8rpx;
}

.note-line {
  height: 3rpx;
  background: rgba(102, 126, 234, 0.35);
  border-radius: 2rpx;
}

.note-line:last-child {
  width: 60%;
}

.note-corner {
  position: absolute;
  top: 16rpx;
  right: 20rpx;
  width: 0;
  height: 0;
  border-left: 12rpx solid transparent;
  border-top: 12rpx solid rgba(102, 126, 234, 0.25);
  animation: cornerFold 3s ease-in-out infinite;
}

@keyframes cornerFold {
  0%, 100% { border-top-color: rgba(102, 126, 234, 0.25); }
  50% { border-top-color: rgba(102, 126, 234, 0.5); }
}

.note-mark {
  position: absolute;
  bottom: 14rpx;
  right: 18rpx;
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #f87171;
  animation: markPulse 2s ease-in-out infinite;
}

@keyframes markPulse {
  0%, 100% { transform: scale(1); opacity: 0.8; }
  50% { transform: scale(1.3); opacity: 1; }
}

/* --- 4. 奖杯（班级PK）--- */
.feat-trophy {
  animation: trophyBounce 2.5s ease-in-out infinite;
}

@keyframes trophyBounce {
  0%, 100% { transform: translateY(0); }
  40% { transform: translateY(-6rpx); }
  60% { transform: translateY(-6rpx); }
}

.trophy-cup {
  position: absolute;
  top: 18rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 36rpx;
  height: 28rpx;
  background: #fbbf24;
  border-radius: 4rpx 4rpx 16rpx 16rpx;
  box-shadow: 0 0 12rpx rgba(251, 191, 36, 0.5);
}

.trophy-cup::before {
  content: '';
  position: absolute;
  top: 4rpx;
  left: -10rpx;
  width: 12rpx;
  height: 18rpx;
  border: 3rpx solid #fbbf24;
  border-right: none;
  border-radius: 8rpx 0 0 8rpx;
}

.trophy-cup::after {
  content: '';
  position: absolute;
  top: 4rpx;
  right: -10rpx;
  width: 12rpx;
  height: 18rpx;
  border: 3rpx solid #fbbf24;
  border-left: none;
  border-radius: 0 8rpx 8rpx 0;
}

.trophy-stem {
  position: absolute;
  top: 46rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 8rpx;
  height: 12rpx;
  background: rgba(255, 255, 255, 0.6);
  border-radius: 0 0 2rpx 2rpx;
}

.trophy-base {
  position: absolute;
  top: 56rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 28rpx;
  height: 6rpx;
  background: rgba(255, 255, 255, 0.6);
  border-radius: 2rpx;
}

.trophy-star {
  position: absolute;
  top: 10rpx;
  right: 14rpx;
  width: 14rpx;
  height: 14rpx;
  background: #fff;
  clip-path: polygon(50% 0%, 61% 35%, 98% 35%, 68% 57%, 79% 91%, 50% 70%, 21% 91%, 32% 57%, 2% 35%, 39% 35%);
  animation: starTwinkle 1.5s ease-in-out infinite;
}

@keyframes starTwinkle {
  0%, 100% { opacity: 0.5; transform: scale(0.8) rotate(0deg); }
  50% { opacity: 1; transform: scale(1.1) rotate(15deg); }
}

/* ===== 登录区域 ===== */
.login-section {
  margin-top: auto;
  width: 100%;
  z-index: 1;
}

.login-btn {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  background: #fff;
  border-radius: 48rpx;
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.12);
  padding: 0;
}

.login-btn::after {
  border: none;
}

.login-btn:active:not(.disabled) {
  opacity: 0.9;
  transform: scale(0.98);
}

.login-btn.disabled {
  opacity: 0.65;
}

.login-btn-text {
  font-size: 32rpx;
  font-weight: bold;
  color: #5a67d8;
}

.agreement {
  text-align: center;
  margin-top: 28rpx;
}

.agreement-text {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
}

.agreement-link {
  font-size: 24rpx;
  color: #fff;
  text-decoration: underline;
  margin-left: 4rpx;
}

/* ===== 底部 ===== */
.footer {
  margin-top: 40rpx;
  z-index: 1;
}

.footer-text {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.5);
  letter-spacing: 2rpx;
}
