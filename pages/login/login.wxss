/* pages/login/login.wxss - 温润古典·书卷风 */
page {
  background: #FBF6F0;
}

.container {
  min-height: 100vh;
  background: #FBF6F0;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 0 40rpx 60rpx;
  position: relative;
  overflow: hidden;
}

/* ===== 山水画背景 ===== */
.bg-painting {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 50vh;
  z-index: 0;
}

/* 渐变遮罩：让山水画底部自然融入米色背景 */
.bg-painting-mask {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 50vh;
  z-index: 1;
  background: linear-gradient(
    180deg,
    rgba(251, 246, 240, 0) 0%,
    rgba(251, 246, 240, 0) 40%,
    rgba(251, 246, 240, 0.3) 60%,
    rgba(251, 246, 240, 0.7) 78%,
    rgba(251, 246, 240, 0.95) 90%,
    #FBF6F0 100%
  );
}

/* ===== Logo 动画书本 ===== */
.logo-section {
  text-align: center;
  z-index: 2;
  margin-top: 46vh;
  margin-bottom: 40rpx;
}

.logo-anim {
  position: relative;
  width: 180rpx;
  height: 180rpx;
  margin: 0 auto 30rpx;
  animation: logoFloat 3s ease-in-out infinite;
}

@keyframes logoFloat {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-16rpx); }
}

/* 书本 */
.book {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 80rpx;
  height: 96rpx;
}

.book-left {
  position: absolute;
  left: 0;
  top: 0;
  width: 38rpx;
  height: 90rpx;
  background: #FFFDF8;
  border-radius: 6rpx 0 0 6rpx;
  transform: skewY(-3deg);
  opacity: 0.95;
  box-shadow: 2rpx 2rpx 12rpx rgba(80, 60, 30, 0.25);
}

.book-right {
  position: absolute;
  right: 0;
  top: 0;
  width: 38rpx;
  height: 90rpx;
  background: rgba(255, 253, 248, 0.88);
  border-radius: 0 6rpx 6rpx 0;
  transform: skewY(3deg);
  animation: pageFlip 3s ease-in-out infinite;
}

@keyframes pageFlip {
  0%, 100% { transform: skewY(3deg); }
  50% { transform: skewY(6deg) rotateY(-8deg); }
}

.book-spine {
  position: absolute;
  left: 50%;
  top: -4rpx;
  width: 6rpx;
  height: 98rpx;
  background: rgba(160, 130, 80, 0.5);
  transform: translateX(-50%);
  border-radius: 3rpx;
}

/* 光晕 */
.logo-glow {
  position: absolute;
  top: 50%;
  left: 50%;
  width: 160rpx;
  height: 160rpx;
  transform: translate(-50%, -50%);
  border-radius: 50%;
  border: 2rpx solid rgba(196, 136, 46, 0.35);
  animation: glowPulse 2.5s ease-in-out infinite;
}

@keyframes glowPulse {
  0%, 100% {
    box-shadow: 0 0 24rpx rgba(196, 136, 46, 0.15);
    transform: translate(-50%, -50%) scale(1);
  }
  50% {
    box-shadow: 0 0 48rpx rgba(196, 136, 46, 0.3);
    transform: translate(-50%, -50%) scale(1.06);
  }
}

.app-name {
  font-size: 50rpx;
  font-weight: bold;
  color: #1A1008;
  margin-bottom: 14rpx;
  letter-spacing: 10rpx;
  text-shadow: 0 2rpx 8rpx rgba(251, 246, 240, 0.8);
}

.app-slogan {
  font-size: 26rpx;
  color: #4A3C30;
  letter-spacing: 4rpx;
  text-shadow: 0 1rpx 6rpx rgba(251, 246, 240, 0.8);
}

/* ========================================
   特色功能图标 — 鲜艳明亮版
   ======================================== */
.features {
  display: flex;
  justify-content: space-around;
  width: 100%;
  z-index: 2;
  margin-bottom: 50rpx;
}

.feature-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.feature-label {
  font-size: 22rpx;
  color: #4A3C30;
  margin-top: 14rpx;
  letter-spacing: 2rpx;
  font-weight: 500;
}

.feat-icon {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.8);
  border: 3rpx solid rgba(196, 136, 46, 0.3);
  position: relative;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(140, 100, 40, 0.12);
}

/* --- 1. 灯泡（智能出题）--- 金黄色 */
.feat-bulb {
  animation: bulbGlow 2.5s ease-in-out infinite;
}

@keyframes bulbGlow {
  0%, 100% { background: rgba(255, 255, 255, 0.8); }
  50% { background: rgba(255, 200, 50, 0.2); }
}

.bulb-body {
  position: absolute;
  top: 20rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 34rpx;
  height: 38rpx;
  border-radius: 50% 50% 8rpx 8rpx;
  background: #E6A817;
  box-shadow: 0 0 20rpx rgba(230, 168, 23, 0.5);
}

.bulb-base {
  position: absolute;
  top: 58rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 24rpx;
  height: 10rpx;
  border-radius: 0 0 4rpx 4rpx;
  background: #C4882E;
}

.bulb-ray {
  position: absolute;
  background: rgba(230, 168, 23, 0.7);
  border-radius: 2rpx;
  animation: rayBlink 2s ease-in-out infinite;
}

.ray-1 { width: 14rpx; height: 4rpx; top: 30rpx; left: 10rpx; transform: rotate(-30deg); animation-delay: 0s; }
.ray-2 { width: 14rpx; height: 4rpx; top: 16rpx; left: 50%; transform: translateX(-50%); animation-delay: 0.4s; }
.ray-3 { width: 14rpx; height: 4rpx; top: 30rpx; right: 10rpx; transform: rotate(30deg); animation-delay: 0.8s; }

@keyframes rayBlink {
  0%, 100% { opacity: 0.3; }
  50% { opacity: 1; }
}

/* --- 2. 柱状图（学习统计）--- 绿色系 */
.feat-chart {
  position: relative;
}

.chart-bar {
  position: absolute;
  bottom: 22rpx;
  width: 14rpx;
  border-radius: 3rpx 3rpx 0 0;
  animation: barGrow 2s ease-in-out infinite;
}

.bar-1 { height: 22rpx; left: 50%; margin-left: -24rpx; background: #7EC8A0; animation-delay: 0s; }
.bar-2 { height: 34rpx; left: 50%; margin-left: -6rpx; background: #4CAF50; animation-delay: 0.3s; }
.bar-3 { height: 46rpx; left: 50%; margin-left: 12rpx; background: #2E8B57; animation-delay: 0.6s; }

.chart-base-line {
  position: absolute;
  bottom: 21rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 54rpx;
  height: 2rpx;
  background: rgba(76, 175, 80, 0.3);
}

@keyframes barGrow {
  0%, 100% { transform: scaleY(1); }
  50% { transform: scaleY(0.6); }
}

/* --- 3. 笔记本（错题本）--- 红色系 */
.feat-note {
  animation: noteWobble 3s ease-in-out infinite;
}

@keyframes noteWobble {
  0%, 100% { transform: rotate(0deg); }
  25% { transform: rotate(2deg); }
  75% { transform: rotate(-2deg); }
}

.note-body {
  position: absolute;
  top: 18rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 50rpx;
  height: 56rpx;
  background: #FFFDF8;
  border-radius: 4rpx 10rpx 10rpx 4rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 8rpx;
  padding: 0 8rpx;
  box-shadow: 2rpx 2rpx 6rpx rgba(100, 80, 50, 0.1);
}

.note-line { height: 3rpx; background: rgba(224, 90, 71, 0.3); border-radius: 2rpx; }
.note-line:last-child { width: 60%; }

.note-corner {
  position: absolute;
  top: 18rpx;
  right: 22rpx;
  width: 0;
  height: 0;
  border-left: 12rpx solid transparent;
  border-top: 12rpx solid rgba(224, 90, 71, 0.3);
  animation: cornerFold 3s ease-in-out infinite;
}

@keyframes cornerFold {
  0%, 100% { border-top-color: rgba(224, 90, 71, 0.3); }
  50% { border-top-color: rgba(224, 90, 71, 0.6); }
}

.note-mark {
  position: absolute;
  bottom: 16rpx;
  right: 20rpx;
  width: 18rpx;
  height: 18rpx;
  border-radius: 50%;
  background: #E05A47;
  animation: markPulse 2s ease-in-out infinite;
  box-shadow: 0 0 8rpx rgba(224, 90, 71, 0.4);
}

@keyframes markPulse {
  0%, 100% { transform: scale(1); opacity: 0.7; }
  50% { transform: scale(1.3); opacity: 1; }
}

/* --- 4. 奖杯（班级PK）--- 明亮金色 */
.feat-trophy { animation: trophyBounce 2.5s ease-in-out infinite; }

@keyframes trophyBounce {
  0%, 100% { transform: translateY(0); }
  40% { transform: translateY(-6rpx); }
  60% { transform: translateY(-6rpx); }
}

.trophy-cup {
  position: absolute;
  top: 20rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 38rpx;
  height: 30rpx;
  background: linear-gradient(180deg, #FFD54F, #E6A817);
  border-radius: 4rpx 4rpx 16rpx 16rpx;
  box-shadow: 0 0 14rpx rgba(230, 168, 23, 0.45);
}

.trophy-cup::before {
  content: '';
  position: absolute;
  top: 4rpx;
  left: -12rpx;
  width: 14rpx;
  height: 20rpx;
  border: 3rpx solid #E6A817;
  border-right: none;
  border-radius: 8rpx 0 0 8rpx;
}

.trophy-cup::after {
  content: '';
  position: absolute;
  top: 4rpx;
  right: -12rpx;
  width: 14rpx;
  height: 20rpx;
  border: 3rpx solid #E6A817;
  border-left: none;
  border-radius: 0 8rpx 8rpx 0;
}

.trophy-stem {
  position: absolute;
  top: 50rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 8rpx;
  height: 12rpx;
  background: #C4882E;
  border-radius: 0 0 2rpx 2rpx;
}

.trophy-base {
  position: absolute;
  top: 60rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 30rpx;
  height: 6rpx;
  background: #C4882E;
  border-radius: 2rpx;
}

.trophy-star {
  position: absolute;
  top: 10rpx;
  right: 14rpx;
  width: 16rpx;
  height: 16rpx;
  background: #FFF8E1;
  clip-path: polygon(50% 0%, 61% 35%, 98% 35%, 68% 57%, 79% 91%, 50% 70%, 21% 91%, 32% 57%, 2% 35%, 39% 35%);
  animation: starTwinkle 1.5s ease-in-out infinite;
}

@keyframes starTwinkle {
  0%, 100% { opacity: 0.4; transform: scale(0.8) rotate(0deg); }
  50% { opacity: 1; transform: scale(1.2) rotate(15deg); }
}

/* ===== 登录区域 ===== */
.login-section {
  margin-top: auto;
  width: 100%;
  z-index: 2;
}

.login-btn {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  background: linear-gradient(135deg, #C4882E, #A56A1F);
  border-radius: 48rpx;
  border: none;
  box-shadow: 0 8rpx 28rpx rgba(196, 136, 46, 0.35);
  padding: 0;
}

.login-btn::after { border: none; }

.login-btn:active:not(.disabled) {
  opacity: 0.9;
  transform: scale(0.98);
}

.login-btn.disabled { opacity: 0.65; }

.login-btn-text {
  font-size: 32rpx;
  font-weight: bold;
  color: #FFFDF8;
  letter-spacing: 6rpx;
}

.agreement {
  text-align: center;
  margin-top: 28rpx;
}

.agreement-text {
  font-size: 24rpx;
  color: rgba(26, 16, 8, 0.45);
}

.agreement-link {
  font-size: 24rpx;
  color: #9E6B2C;
  text-decoration: underline;
  margin-left: 4rpx;
}

/* ===== 底部 ===== */
.footer {
  margin-top: 40rpx;
  z-index: 2;
}

.footer-text {
  font-size: 24rpx;
  color: rgba(26, 16, 8, 0.35);
  letter-spacing: 2rpx;
}
