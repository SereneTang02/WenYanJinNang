/* pages/profile/profile.wxss */
page {
  background: #f0f2f5;
}

.container {
  padding: 0 0 60rpx;
}

/* ===== 用户信息卡片 ===== */
.user-card {
  background: linear-gradient(160deg, #4A90E2 0%, #357ABD 50%, #2E6BA6 100%);
  padding: 50rpx 36rpx 40rpx;
  border-radius: 0 0 48rpx 48rpx;
  margin-bottom: 24rpx;
  position: relative;
  overflow: hidden;
}

.user-card::after {
  content: '';
  position: absolute;
  top: -60rpx;
  right: -60rpx;
  width: 240rpx;
  height: 240rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.06);
  pointer-events: none;
}

/* 横排布局 */
.profile-row {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
  position: relative;
  z-index: 1;
}

/* 头像按钮 */
.avatar-btn {
  width: 120rpx !important;
  height: 120rpx !important;
  min-height: 0 !important;
  padding: 0 !important;
  margin: 0 28rpx 0 0 !important;
  background: none !important;
  border: none !important;
  border-radius: 50% !important;
  overflow: hidden;
  flex-shrink: 0;
  line-height: 1 !important;
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-btn::after {
  display: none;
}

.avatar-img {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 255, 255, 0.4);
}

/* 右侧信息 */
.profile-info {
  flex: 1;
  min-width: 0;
}

.nickname-input {
  font-size: 36rpx;
  font-weight: bold;
  color: #fff;
  height: 60rpx;
  line-height: 60rpx;
  margin-bottom: 10rpx;
}

.nickname-placeholder {
  color: rgba(255, 255, 255, 0.5);
  font-weight: normal;
}

.role-tag {
  display: inline-block;
  padding: 6rpx 20rpx;
  border-radius: 16rpx;
  font-size: 24rpx;
  background: rgba(255, 255, 255, 0.18);
  color: #fff;
}

/* 提示文字 */
.tip-text {
  text-align: center;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.5);
  margin-bottom: 4rpx;
  position: relative;
  z-index: 1;
}

/* 保存按钮 */
.save-wx-btn {
  width: 100% !important;
  height: 72rpx;
  line-height: 72rpx;
  background: #fff !important;
  color: #4A90E2 !important;
  border-radius: 36rpx;
  font-size: 30rpx;
  font-weight: bold;
  border: none;
  text-align: center;
  padding: 0;
  margin-top: 16rpx;
  position: relative;
  z-index: 1;
}

.save-wx-btn::after {
  display: none;
}

/* ===== 学习数据卡片 ===== */
.data-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 36rpx 30rpx;
  margin: 0 24rpx 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.data-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 28rpx;
}

.data-grid {
  display: flex;
  justify-content: space-around;
}

.data-item {
  text-align: center;
}

.data-value {
  font-size: 44rpx;
  font-weight: bold;
  color: #4A90E2;
  margin-bottom: 8rpx;
}

.data-label {
  font-size: 24rpx;
  color: #999;
}

/* ===== 功能菜单 ===== */
.menu-card {
  background: #fff;
  border-radius: 20rpx;
  margin: 0 24rpx 24rpx;
  padding: 8rpx 0;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
  overflow: hidden;
}

.menu-row {
  display: flex;
  align-items: center;
  padding: 28rpx 30rpx;
}

.menu-divider {
  height: 1rpx;
  background: #f0f0f0;
  margin: 0 30rpx;
}

.menu-icon-wrap {
  width: 72rpx;
  height: 72rpx;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.icon-blue {
  background: linear-gradient(135deg, #4facfe, #00f2fe);
}

.icon-red {
  background: linear-gradient(135deg, #f093fb, #f5576c);
}

.menu-icon-text {
  font-size: 28rpx;
  font-weight: bold;
  color: #fff;
}

.menu-info {
  flex: 1;
}

.menu-name {
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
  margin-bottom: 4rpx;
}

.menu-desc {
  font-size: 22rpx;
  color: #bbb;
}

.menu-arrow {
  font-size: 40rpx;
  color: #d0d0d0;
}

/* ===== 退出登录 ===== */
.logout-area {
  padding: 0 24rpx;
  margin-top: 16rpx;
}

.logout-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: #fff;
  color: #ff4d4f;
  border-radius: 20rpx;
  font-size: 30rpx;
  border: none;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.logout-btn::after {
  border: none;
}
