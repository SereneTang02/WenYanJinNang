/* pages/profile/profile.wxss - 温润古典·书卷风 */
page {
  background: #FBF6F0;
}

.container {
  padding: 0 0 60rpx;
}

/* ===== 用户信息卡片 ===== */
.user-card {
  background: linear-gradient(180deg, #E8D5B8 0%, #F2E8D6 60%, #FBF6F0 100%);
  padding: 50rpx 36rpx 40rpx;
  border-radius: 0 0 48rpx 48rpx;
  margin-bottom: 24rpx;
  position: relative;
  overflow: hidden;
}

.user-card::after {
  content: '';
  position: absolute;
  top: -60rpx;
  right: -60rpx;
  width: 240rpx;
  height: 240rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(200, 168, 124, 0.15) 0%, transparent 70%);
  pointer-events: none;
}

/* 横排布局 */
.profile-row {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
  position: relative;
  z-index: 1;
}

/* 头像按钮 */
.avatar-btn {
  width: 120rpx !important;
  height: 120rpx !important;
  min-height: 0 !important;
  padding: 0 !important;
  margin: 0 28rpx 0 0 !important;
  background: none !important;
  border: none !important;
  border-radius: 50% !important;
  overflow: hidden;
  flex-shrink: 0;
  line-height: 1 !important;
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-btn::after {
  display: none;
}

.avatar-img {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(200, 168, 124, 0.4);
}

/* 右侧信息 */
.profile-info {
  flex: 1;
  min-width: 0;
}

.nickname-input {
  font-size: 36rpx;
  font-weight: bold;
  color: #1A1008;
  height: 60rpx;
  line-height: 60rpx;
  margin-bottom: 10rpx;
}

.nickname-placeholder {
  color: rgba(74, 55, 40, 0.4);
  font-weight: normal;
}

.role-tag {
  display: inline-block;
  padding: 8rpx 24rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  background: rgba(200, 168, 124, 0.15);
  color: #9E6B2C;
  border: 1rpx solid rgba(200, 175, 140, 0.25);
}

/* 提示文字 */
.tip-text {
  text-align: center;
  font-size: 22rpx;
  color: #5C4D3E;
  margin-bottom: 4rpx;
  position: relative;
  z-index: 1;
}

/* 保存按钮 */
.save-wx-btn {
  width: 100% !important;
  height: 72rpx;
  line-height: 72rpx;
  background: rgba(255, 255, 255, 0.7) !important;
  color: #9E6B2C !important;
  border-radius: 36rpx;
  font-size: 30rpx;
  font-weight: bold;
  border: 2rpx solid #C9B18A !important;
  text-align: center;
  padding: 0;
  margin-top: 16rpx;
  position: relative;
  z-index: 1;
}

.save-wx-btn::after {
  display: none;
}

/* ===== 学习数据卡片 ===== */
.data-card {
  background: rgba(255, 255, 255, 0.88);
  border: 1rpx solid rgba(200, 175, 140, 0.18);
  border-radius: 24rpx;
  padding: 36rpx 30rpx;
  margin: 0 24rpx 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(166, 138, 100, 0.08);
  backdrop-filter: blur(10rpx);
}

.data-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #1A1008;
  margin-bottom: 28rpx;
}

.data-grid {
  display: flex;
  justify-content: space-around;
}

.data-item {
  text-align: center;
}

.data-value {
  font-size: 44rpx;
  font-weight: bold;
  color: #C4882E;
  margin-bottom: 8rpx;
}

.data-label {
  font-size: 24rpx;
  color: #5C4D3E;
}

/* ===== 功能菜单 ===== */
.menu-card {
  background: rgba(255, 255, 255, 0.88);
  border: 1rpx solid rgba(200, 175, 140, 0.18);
  border-radius: 24rpx;
  margin: 0 24rpx 24rpx;
  padding: 8rpx 0;
  box-shadow: 0 4rpx 20rpx rgba(166, 138, 100, 0.08);
  overflow: hidden;
  backdrop-filter: blur(10rpx);
}

.menu-row {
  display: flex;
  align-items: center;
  padding: 28rpx 30rpx;
}

.menu-divider {
  height: 1rpx;
  background: rgba(200, 175, 140, 0.15);
  margin: 0 30rpx;
}

.menu-icon-wrap {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.icon-blue {
  background: rgba(107, 152, 184, 0.08);
  border: 2rpx solid #3A8FC2;
}

.icon-red {
  background: rgba(201, 107, 92, 0.08);
  border: 2rpx solid #E05A47;
}

.menu-icon-text {
  font-size: 28rpx;
  font-weight: bold;
  color: #4A3C30;
}

.icon-blue .menu-icon-text {
  color: #3A8FC2;
}

.icon-red .menu-icon-text {
  color: #E05A47;
}

.menu-info {
  flex: 1;
}

.menu-name {
  font-size: 30rpx;
  color: #1A1008;
  font-weight: 500;
  margin-bottom: 4rpx;
}

.menu-desc {
  font-size: 22rpx;
  color: #5C4D3E;
}

.menu-arrow {
  font-size: 40rpx;
  color: #C9B18A;
}

/* ===== 退出登录 ===== */
.logout-area {
  padding: 0 24rpx;
  margin-top: 16rpx;
}

.logout-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: rgba(255, 255, 255, 0.88);
  color: #E05A47;
  border-radius: 24rpx;
  font-size: 30rpx;
  border: 1rpx solid rgba(200, 175, 140, 0.18);
  box-shadow: 0 4rpx 20rpx rgba(166, 138, 100, 0.08);
}

.logout-btn::after {
  border: none;
}
