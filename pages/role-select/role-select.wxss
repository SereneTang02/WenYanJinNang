/* pages/role-select/role-select.wxss - 温润古典·书卷风 */
page {
  background: #FBF6F0;
}

.container {
  padding: 0 0 60rpx;
  min-height: 100vh;
}

/* ===== 顶部英雄卡片 ===== */
.hero-card {
  background: linear-gradient(180deg, #E8D5B8 0%, #F2E8D6 60%, #FBF6F0 100%);
  padding: 80rpx 36rpx 60rpx;
  color: #1A1008;
  border-radius: 0 0 48rpx 48rpx;
  margin-bottom: 36rpx;
  text-align: center;
  position: relative;
  overflow: hidden;
}

.hero-card::after {
  content: '';
  position: absolute;
  top: -50rpx;
  right: -50rpx;
  width: 220rpx;
  height: 220rpx;
  border-radius: 50%;
  background: rgba(200, 168, 124, 0.1);
}

.hero-title {
  font-size: 48rpx;
  font-weight: bold;
  color: #1A1008;
  margin-bottom: 12rpx;
}

.hero-sub {
  font-size: 26rpx;
  color: #4A3C30;
}

/* ===== 区域标题 ===== */
.section-label {
  font-size: 32rpx;
  font-weight: bold;
  color: #1A1008;
  padding: 0 36rpx;
  margin-bottom: 20rpx;
}

/* ===== 角色卡片 ===== */
.role-card {
  background: rgba(255, 255, 255, 0.88);
  border: 1rpx solid rgba(200, 175, 140, 0.18);
  border-radius: 24rpx;
  padding: 36rpx 30rpx;
  margin: 0 24rpx 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(166, 138, 100, 0.08);
  display: flex;
  align-items: center;
  transition: all 0.3s;
}

.role-card:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 10rpx rgba(166, 138, 100, 0.12);
}

.role-left {
  margin-right: 24rpx;
  flex-shrink: 0;
}

.role-icon-wrap {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.icon-blue {
  background: rgba(107, 152, 184, 0.08);
  border: 2rpx solid #3A8FC2;
}

.icon-purple {
  background: rgba(166, 139, 107, 0.08);
  border: 2rpx solid #9E6B2C;
}

.role-icon-text {
  font-size: 36rpx;
  font-weight: bold;
}

.icon-blue .role-icon-text {
  color: #3A8FC2;
}

.icon-purple .role-icon-text {
  color: #9E6B2C;
}

.role-center {
  flex: 1;
  min-width: 0;
}

.role-name {
  font-size: 34rpx;
  font-weight: bold;
  color: #1A1008;
  margin-bottom: 8rpx;
}

.role-desc-list {
  line-height: 1.5;
}

.role-desc-item {
  font-size: 24rpx;
  color: #5C4D3E;
}

.role-arrow {
  font-size: 36rpx;
  color: #C9B18A;
  flex-shrink: 0;
  margin-left: 12rpx;
}

/* ===== 提示 ===== */
.hint-card {
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 40rpx 24rpx 0;
  padding: 24rpx;
  background: rgba(200, 168, 124, 0.1);
  border-radius: 20rpx;
}

.hint-icon-wrap {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  background: rgba(200, 168, 124, 0.15);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 12rpx;
  flex-shrink: 0;
}

.hint-icon-text {
  font-size: 22rpx;
  font-weight: bold;
  color: #C4882E;
}

.hint-text {
  font-size: 24rpx;
  color: #9E6B2C;
}
