/* pages/role-select/role-select.wxss */
page {
  background: #f0f2f5;
}

.container {
  padding: 0 0 60rpx;
  min-height: 100vh;
}

/* ===== 顶部英雄卡片 ===== */
.hero-card {
  background: linear-gradient(160deg, #667eea 0%, #5a67d8 50%, #4c51bf 100%);
  padding: 80rpx 36rpx 60rpx;
  color: #fff;
  border-radius: 0 0 48rpx 48rpx;
  margin-bottom: 36rpx;
  text-align: center;
  position: relative;
  overflow: hidden;
}

.hero-card::after {
  content: '';
  position: absolute;
  top: -50rpx;
  right: -50rpx;
  width: 220rpx;
  height: 220rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.06);
}

.hero-title {
  font-size: 48rpx;
  font-weight: bold;
  margin-bottom: 12rpx;
}

.hero-sub {
  font-size: 26rpx;
  opacity: 0.75;
}

/* ===== 区域标题 ===== */
.section-label {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  padding: 0 36rpx;
  margin-bottom: 20rpx;
}

/* ===== 角色卡片 ===== */
.role-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 36rpx 30rpx;
  margin: 0 24rpx 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
  display: flex;
  align-items: center;
}

.role-card:active {
  transform: scale(0.98);
  opacity: 0.9;
}

.role-left {
  margin-right: 24rpx;
  flex-shrink: 0;
}

.role-icon-wrap {
  width: 88rpx;
  height: 88rpx;
  border-radius: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.icon-blue {
  background: linear-gradient(135deg, #4facfe, #00f2fe);
}

.icon-purple {
  background: linear-gradient(135deg, #667eea, #764ba2);
}

.role-icon-text {
  font-size: 36rpx;
  font-weight: bold;
  color: #fff;
}

.role-center {
  flex: 1;
  min-width: 0;
}

.role-name {
  font-size: 34rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}

.role-desc-list {
  line-height: 1.5;
}

.role-desc-item {
  font-size: 24rpx;
  color: #999;
}

.role-arrow {
  font-size: 36rpx;
  color: #d0d0d0;
  flex-shrink: 0;
  margin-left: 12rpx;
}

/* ===== 提示 ===== */
.hint-card {
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 40rpx 24rpx 0;
  padding: 24rpx;
  background: rgba(102, 126, 234, 0.08);
  border-radius: 16rpx;
}

.hint-icon-wrap {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  background: rgba(102, 126, 234, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 12rpx;
  flex-shrink: 0;
}

.hint-icon-text {
  font-size: 22rpx;
  font-weight: bold;
  color: #667eea;
}

.hint-text {
  font-size: 24rpx;
  color: #667eea;
}
