<!--pages/records/records.wxml-->
<view class="container">
  <!-- 顶部栏 -->
  <view class="hero-card">
    <view class="hero-title">学习记录</view>
    <view class="hero-sub">查看错题和收藏的词汇</view>
    <view class="hero-stats">
      <view class="hero-stat">
        <text class="hero-stat-num">{{errorWordsCount}}</text>
        <text class="hero-stat-label">错题</text>
      </view>
      <view class="hero-stat-divider"></view>
      <view class="hero-stat">
        <text class="hero-stat-num">{{favoriteWordsCount}}</text>
        <text class="hero-stat-label">收藏</text>
      </view>
      <view class="hero-stat-divider"></view>
      <view class="hero-stat">
        <text class="hero-stat-num">{{totalStudied}}</text>
        <text class="hero-stat-label">已学</text>
      </view>
    </view>
  </view>

  <!-- 记录入口 -->
  <view class="section-label">我的记录</view>

  <view class="record-card" bindtap="goToErrorWords">
    <view class="record-icon-wrap icon-red">
      <text class="record-icon-text">错</text>
    </view>
    <view class="record-info">
      <view class="record-name">错题本</view>
      <view class="record-desc">复习答错的词汇，针对性加强</view>
    </view>
    <view class="record-right">
      <view class="record-badge" wx:if="{{errorWordsCount > 0}}">{{errorWordsCount}}</view>
      <view class="record-arrow">›</view>
    </view>
  </view>

  <view class="record-card" bindtap="goToFavorites">
    <view class="record-icon-wrap icon-yellow">
      <text class="record-icon-text">藏</text>
    </view>
    <view class="record-info">
      <view class="record-name">收藏本</view>
      <view class="record-desc">查看收藏的重点词汇</view>
    </view>
    <view class="record-right">
      <view class="record-badge badge-yellow" wx:if="{{favoriteWordsCount > 0}}">{{favoriteWordsCount}}</view>
      <view class="record-arrow">›</view>
    </view>
  </view>

  <view class="record-card" bindtap="goToWordList">
    <view class="record-icon-wrap icon-blue">
      <text class="record-icon-text">词</text>
    </view>
    <view class="record-info">
      <view class="record-name">实词列表</view>
      <view class="record-desc">浏览全部实词</view>
    </view>
    <view class="record-right">
      <view class="record-arrow">›</view>
    </view>
  </view>
</view>
