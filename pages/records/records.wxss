/* pages/records/records.wxss - 温润古典·书卷风 */
page {
  background: #FBF6F0;
}

.container {
  padding: 0 0 40rpx;
}

/* ===== 顶部英雄卡片 ===== */
.hero-card {
  background: linear-gradient(180deg, #E8D5B8 0%, #F2E8D6 60%, #FBF6F0 100%);
  padding: 50rpx 36rpx 40rpx;
  color: #1A1008;
  border-radius: 0 0 48rpx 48rpx;
  margin-bottom: 36rpx;
  position: relative;
  overflow: hidden;
}

.hero-card::after {
  content: '';
  position: absolute;
  top: -60rpx;
  right: -60rpx;
  width: 240rpx;
  height: 240rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(200, 168, 124, 0.15) 0%, transparent 70%);
}

.hero-title {
  font-size: 44rpx;
  font-weight: bold;
  margin-bottom: 8rpx;
  color: #1A1008;
}

.hero-sub {
  font-size: 26rpx;
  color: #4A3C30;
  margin-bottom: 36rpx;
}

.hero-stats {
  display: flex;
  align-items: center;
  justify-content: space-around;
  background: rgba(255, 255, 255, 0.45);
  border-radius: 20rpx;
  padding: 24rpx 0;
  border: 1rpx solid rgba(200, 175, 140, 0.18);
  backdrop-filter: blur(10rpx);
}

.hero-stat {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.hero-stat-num {
  font-size: 44rpx;
  font-weight: bold;
  margin-bottom: 4rpx;
  color: #C4882E;
}

.hero-stat-label {
  font-size: 22rpx;
  color: #4A3C30;
}

.hero-stat-divider {
  width: 1rpx;
  height: 48rpx;
  background: rgba(200, 168, 124, 0.3);
}

/* ===== 区域标题 ===== */
.section-label {
  font-size: 32rpx;
  font-weight: bold;
  color: #1A1008;
  padding: 0 36rpx;
  margin-bottom: 20rpx;
}

/* ===== 记录卡片 ===== */
.record-card {
  background: rgba(255, 255, 255, 0.88);
  border: 1rpx solid rgba(200, 175, 140, 0.18);
  border-radius: 24rpx;
  padding: 30rpx;
  margin: 0 24rpx 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(166, 138, 100, 0.08);
  display: flex;
  align-items: center;
  transition: all 0.3s;
}

.record-card:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 10rpx rgba(166, 138, 100, 0.12);
}

.record-icon-wrap {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.icon-red {
  background: rgba(201, 107, 92, 0.08);
  border: 2rpx solid #E05A47;
}

.icon-yellow {
  background: rgba(200, 168, 124, 0.08);
  border: 2rpx solid #C4882E;
}

.icon-blue {
  background: rgba(107, 152, 184, 0.08);
  border: 2rpx solid #3A8FC2;
}

.record-icon-text {
  font-size: 30rpx;
  font-weight: bold;
  color: #9E6B2C;
}

.icon-red .record-icon-text {
  color: #E05A47;
}

.icon-yellow .record-icon-text {
  color: #C4882E;
}

.icon-blue .record-icon-text {
  color: #3A8FC2;
}

.record-info {
  flex: 1;
  min-width: 0;
}

.record-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #1A1008;
  margin-bottom: 6rpx;
}

.record-desc {
  font-size: 24rpx;
  color: #5C4D3E;
}

.record-right {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-shrink: 0;
}

.record-badge {
  min-width: 40rpx;
  height: 40rpx;
  line-height: 40rpx;
  padding: 0 12rpx;
  border-radius: 20rpx;
  background: rgba(201, 107, 92, 0.12);
  color: #E05A47;
  font-size: 22rpx;
  font-weight: bold;
  text-align: center;
}

.badge-yellow {
  background: rgba(200, 168, 124, 0.12);
  color: #C4882E;
}

.record-arrow {
  font-size: 32rpx;
  color: #C9B18A;
}

/* ===== 学习趋势 ===== */
.trend-card {
  background: rgba(255, 255, 255, 0.88);
  border: 1rpx solid rgba(200, 175, 140, 0.18);
  border-radius: 24rpx;
  padding: 32rpx 24rpx;
  margin: 0 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(166, 138, 100, 0.08);
}

.trend-bar-area {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  margin-bottom: 20rpx;
  padding: 0 8rpx;
}

.trend-col {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
  gap: 8rpx;
}

.trend-count {
  font-size: 22rpx;
  color: #4A3C30;
  font-weight: 500;
}

.trend-bar-bg {
  width: 36rpx;
  height: 140rpx;
  background: rgba(212, 196, 168, 0.2);
  border-radius: 18rpx;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
}

.trend-bar-fill {
  width: 100%;
  background: linear-gradient(180deg, #C4882E, #E8C36A);
  border-radius: 18rpx;
  transition: height 0.4s ease;
  min-height: 0;
}

.trend-date {
  font-size: 20rpx;
  color: #5C4D3E;
}

.trend-summary {
  text-align: center;
  font-size: 24rpx;
  color: #5C4D3E;
}
