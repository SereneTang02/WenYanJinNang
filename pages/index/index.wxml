<!--pages/index/index.wxml-->
<view class="container">
  <!-- 顶部统计卡片 -->
  <view class="welcome-card">
    <view class="welcome-title">古文实词背诵</view>
    <view class="welcome-subtitle">学习古文实词，提升文言文阅读能力</view>
    <view class="stats-row">
      <view class="stat-item">
        <text class="stat-num">{{stats.totalStudied}}</text>
        <text class="stat-label">已学习</text>
      </view>
      <view class="stat-item">
        <text class="stat-num">{{stats.totalWords}}</text>
        <text class="stat-label">总词汇</text>
      </view>
      <view class="stat-item">
        <text class="stat-num">{{stats.accuracy}}%</text>
        <text class="stat-label">正确率</text>
      </view>
    </view>
  </view>

  <!-- 自主背诵 -->
  <view class="section-card">
    <view class="section-title">自主背诵</view>
    <button class="btn-primary" bindtap="startRandomStudy">随机背诵</button>
    <button class="btn-outline" bindtap="goToCategory">分类学习</button>
  </view>

  <!-- 每日学习 -->
  <view class="section-label">每日学习</view>
  <view class="daily-card" bindtap="goPractice">
    <view class="daily-icon">📝</view>
    <view class="daily-title">练习测试</view>
    <view class="daily-desc">通过测试巩固记忆</view>
  </view>
</view>
