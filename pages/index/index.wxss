/* pages/index/index.wxss */
page {
  background: #f0f2f5;
}

.container {
  padding: 0 0 40rpx;
}

/* 顶部渐变卡片 */
.welcome-card {
  background: linear-gradient(160deg, #4A90E2 0%, #5BA3F5 100%);
  padding: 60rpx 40rpx 50rpx;
  color: #fff;
  text-align: center;
  border-radius: 0 0 40rpx 40rpx;
  margin-bottom: 40rpx;
}

.welcome-title {
  font-size: 52rpx;
  font-weight: bold;
  margin-bottom: 16rpx;
}

.welcome-subtitle {
  font-size: 28rpx;
  opacity: 0.85;
  margin-bottom: 50rpx;
}

.stats-row {
  display: flex;
  justify-content: space-around;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-num {
  font-size: 52rpx;
  font-weight: bold;
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 24rpx;
  opacity: 0.85;
}

/* 白色功能卡片 */
.section-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 40rpx 30rpx;
  margin: 0 24rpx 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.06);
}

.section-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 30rpx;
}

/* 实心按钮 */
.btn-primary {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  background: #4A90E2;
  color: #fff;
  border-radius: 16rpx;
  font-size: 32rpx;
  text-align: center;
  margin-bottom: 20rpx;
  border: none;
}

/* 描边按钮 */
.btn-outline {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  background: #fff;
  color: #4A90E2;
  border-radius: 16rpx;
  font-size: 32rpx;
  text-align: center;
  border: 2rpx solid #4A90E2;
  box-sizing: border-box;
}

/* 每日学习标签 */
.section-label {
  font-size: 34rpx;
  font-weight: bold;
  color: #333;
  padding: 0 24rpx;
  margin-bottom: 20rpx;
}

/* 每日学习卡片 */
.daily-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 50rpx 30rpx;
  margin: 0 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.06);
  display: flex;
  flex-direction: column;
  align-items: center;
}

.daily-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.daily-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 12rpx;
}

.daily-desc {
  font-size: 26rpx;
  color: #999;
}
