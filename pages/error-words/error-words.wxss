/* pages/error-words/error-words.wxss - 温润古典·书卷风 */
page {
  background: #FBF6F0;
}

.container {
  padding: 0 0 40rpx;
}

/* ===== Hero 头部区 ===== */
.hero-card {
  background: linear-gradient(180deg, #E05A47 0%, #E0A090 50%, #FBF6F0 100%);
  padding: 50rpx 36rpx 40rpx;
  color: #fff;
  border-radius: 0 0 48rpx 48rpx;
  margin-bottom: 36rpx;
  position: relative;
  overflow: hidden;
}

.hero-card::after {
  content: '';
  position: absolute;
  top: -60rpx;
  right: -60rpx;
  width: 240rpx;
  height: 240rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(255, 255, 255, 0.1) 0%, transparent 70%);
}

.hero-top {
  display: flex;
  align-items: center;
  margin-bottom: 36rpx;
}

.hero-icon-wrap {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.2);
  border: 2rpx solid rgba(255, 255, 255, 0.35);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
}

.hero-icon-text {
  font-size: 32rpx;
  font-weight: bold;
  color: #fff;
}

.hero-info {
  flex: 1;
}

.hero-title {
  font-size: 40rpx;
  font-weight: bold;
  margin-bottom: 6rpx;
}

.hero-sub {
  font-size: 26rpx;
  opacity: 0.85;
}

/* 统计行 */
.stats-row {
  display: flex;
  justify-content: space-around;
  align-items: center;
  background: rgba(255, 255, 255, 0.25);
  border: 1rpx solid rgba(255, 255, 255, 0.2);
  border-radius: 20rpx;
  padding: 24rpx 0;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.stat-num {
  font-size: 48rpx;
  font-weight: bold;
  margin-bottom: 6rpx;
}

.stat-label {
  font-size: 22rpx;
  opacity: 0.85;
}

.stat-divider {
  width: 1rpx;
  height: 50rpx;
  background: rgba(255, 255, 255, 0.3);
}

/* ===== 操作按钮区 ===== */
.action-bar {
  padding: 0 24rpx;
  margin-bottom: 36rpx;
}

.action-card {
  background: rgba(255, 255, 255, 0.88);
  border: 1rpx solid rgba(200, 175, 140, 0.18);
  border-radius: 24rpx;
  padding: 24rpx 28rpx;
  box-shadow: 0 4rpx 20rpx rgba(166, 138, 100, 0.08);
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
  transition: all 0.3s;
}

.action-card:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 10rpx rgba(166, 138, 100, 0.12);
}

.action-left {
  display: flex;
  align-items: center;
}

.action-icon-wrap {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
}

.action-icon-text {
  font-size: 32rpx;
  font-weight: bold;
}

.practice-bg {
  background: rgba(107, 152, 184, 0.08);
  border: 2rpx solid #3A8FC2;
}

.practice-bg .action-icon-text {
  color: #3A8FC2;
}

.focus-bg {
  background: rgba(201, 107, 92, 0.08);
  border: 2rpx solid #E05A47;
}

.focus-bg .action-icon-text {
  color: #E05A47;
}

.action-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #1A1008;
  margin-bottom: 4rpx;
}

.action-desc {
  font-size: 22rpx;
  color: #5C4D3E;
}

.action-arrow {
  font-size: 32rpx;
  color: #C9B18A;
}

/* ===== 段落标题 ===== */
.section-label {
  font-size: 32rpx;
  font-weight: bold;
  color: #1A1008;
  padding: 0 36rpx;
  margin-bottom: 20rpx;
}

/* ===== 词卡列表 ===== */
.word-list {
  flex: 1;
  height: calc(100vh - 680rpx);
}

.word-list-inner {
  padding: 0 24rpx;
}

.word-card {
  background-color: rgba(255, 255, 255, 0.88);
  border: 1rpx solid rgba(200, 175, 140, 0.18);
  border-radius: 24rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(166, 138, 100, 0.08);
  position: relative;
  transition: all 0.3s;
  border-left: 8rpx solid transparent;
  box-sizing: border-box;
}

.word-card:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 10rpx rgba(166, 138, 100, 0.12);
}

/* 词卡颜色等级 */
.card-white {
  background-color: rgba(255, 255, 255, 0.88);
  border-left-color: #C9B18A;
}

.card-orange {
  background-color: rgba(200, 168, 124, 0.06);
  border-left-color: #C4882E;
}

.card-red {
  background-color: rgba(201, 107, 92, 0.06);
  border-left-color: #E05A47;
}

/* 第一行：词 + 词性 + 徽章 */
.word-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 20rpx;
}

.word-title {
  display: flex;
  align-items: center;
}

.word-text {
  font-size: 48rpx;
  font-weight: bold;
  color: #1A1008;
  margin-right: 16rpx;
}

.category-tag {
  font-size: 22rpx;
  color: #C4882E;
  background-color: rgba(200, 168, 124, 0.1);
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

/* 状态徽章 */
.error-badge {
  padding: 6rpx 16rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
}

.badge-white {
  background-color: rgba(200, 168, 124, 0.1);
}

.badge-white .badge-text {
  color: #C4882E;
}

.badge-orange {
  background-color: rgba(200, 168, 124, 0.15);
}

.badge-orange .badge-text {
  color: #9E6B2C;
  font-weight: bold;
}

.badge-red {
  background-color: rgba(201, 107, 92, 0.1);
}

.badge-red .badge-text {
  color: #E05A47;
  font-weight: bold;
}

.badge-text {
  font-size: 24rpx;
}

/* 标签行 */
.tags-row {
  display: flex;
  flex-wrap: wrap;
  margin-bottom: 20rpx;
}

.tag {
  padding: 6rpx 18rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  margin-right: 12rpx;
  margin-bottom: 8rpx;
}

.tag-grade {
  background-color: rgba(123, 175, 110, 0.1);
  color: #4CAF50;
}

.tag-difficulty {
  background-color: rgba(200, 168, 124, 0.1);
  color: #9E6B2C;
}

.tag-yi-ci-duo-yi {
  background-color: rgba(200, 168, 124, 0.1);
  color: #C4882E;
}

.tag-zhong-kao-gao-pin {
  background-color: rgba(201, 107, 92, 0.08);
  color: #E05A47;
}

.tag-duo-yin-zi {
  background-color: rgba(107, 152, 184, 0.08);
  color: #3A8FC2;
}

/* 错题统计条 */
.error-stats {
  display: flex;
  align-items: center;
  padding: 14rpx 20rpx;
  background-color: rgba(212, 196, 168, 0.1);
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  font-size: 24rpx;
}

.stats-orange {
  background-color: rgba(200, 168, 124, 0.1);
}

.stats-red {
  background-color: rgba(201, 107, 92, 0.08);
}

.stat-correct {
  color: #4CAF50;
}

.stats-sep {
  color: #C9B18A;
  margin: 0 16rpx;
}

.stat-wrong {
  color: #E05A47;
}

.stat-diff {
  color: #5C4D3E;
  margin-left: 16rpx;
}

/* 卡片操作 */
.card-actions {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 18rpx;
  border-top: 1rpx solid rgba(200, 175, 140, 0.15);
}

.action-link {
  font-size: 26rpx;
  color: #5C4D3E;
}

.action-link.primary {
  color: #C4882E;
  font-weight: bold;
}

/* ===== 空状态 ===== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 150rpx 50rpx;
}

.empty-icon-wrap {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: rgba(123, 175, 110, 0.08);
  border: 2rpx solid #4CAF50;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 30rpx;
}

.empty-icon-text {
  font-size: 48rpx;
  font-weight: bold;
  color: #4CAF50;
}

.empty-text {
  font-size: 36rpx;
  font-weight: bold;
  color: #1A1008;
  margin-bottom: 20rpx;
}

.empty-hint {
  font-size: 28rpx;
  color: #5C4D3E;
}
