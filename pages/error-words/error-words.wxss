/* pages/error-words/error-words.wxss */
.container {
  min-height: 100vh;
  background-color: #f5f5f5;
}

/* 顶部统计区 */
.stats-header {
  background: linear-gradient(135deg, #ff6b6b 0%, #ee5a6f 100%);
  padding: 50rpx 30rpx;
  display: flex;
  justify-content: space-around;
  align-items: center;
  box-shadow: 0 4rpx 12rpx rgba(255, 107, 107, 0.3);
}

.stats-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stats-number {
  font-size: 64rpx;
  font-weight: bold;
  color: #fff;
  line-height: 1.2;
  margin-bottom: 10rpx;
}

.stats-label {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.9);
}

.stats-divider {
  width: 2rpx;
  height: 80rpx;
  background-color: rgba(255, 255, 255, 0.3);
}

/* 操作按钮栏 */
.action-bar {
  display: flex;
  padding: 20rpx;
  gap: 20rpx;
  background-color: #fff;
  border-bottom: 1rpx solid #f0f0f0;
}

.action-btn {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
  font-weight: bold;
  border: none;
}

.btn-primary {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
}

.btn-danger {
  background: linear-gradient(135deg, #ff6b6b 0%, #ee5a6f 100%);
  color: #fff;
}

/* 词卡列表 */
.word-list {
  flex: 1;
  padding: 20rpx;
  height: calc(100vh - 300rpx);
}

.word-card {
  background-color: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
  position: relative;
  transition: all 0.3s;
  border-left: 8rpx solid transparent;
}

.word-card:active {
  transform: scale(0.98);
}

/* 词卡颜色等级 */
.card-white {
  background-color: #fff;
  border-left-color: #e8e8e8;
}

.card-orange {
  background-color: #fff8f0;
  border-left-color: #fa8c16;
}

.card-red {
  background-color: #fff1f0;
  border-left-color: #ff4d4f;
}

/* 第一行：词 + 词性 + 徽章 */
.word-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 20rpx;
}

.word-title {
  display: flex;
  align-items: center;
}

.word-text {
  font-size: 48rpx;
  font-weight: bold;
  color: #333;
  margin-right: 16rpx;
}

.category-tag {
  font-size: 22rpx;
  color: #666;
  background-color: #f0f0f0;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

/* 状态徽章 */
.error-badge {
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  flex-shrink: 0;
}

.badge-white {
  background-color: rgba(250, 173, 20, 0.1);
}

.badge-white .badge-text {
  color: #faad14;
}

.badge-orange {
  background-color: rgba(250, 140, 22, 0.12);
}

.badge-orange .badge-text {
  color: #fa8c16;
  font-weight: bold;
}

.badge-red {
  background-color: rgba(255, 77, 79, 0.12);
}

.badge-red .badge-text {
  color: #ff4d4f;
  font-weight: bold;
}

.badge-text {
  font-size: 24rpx;
}

/* 标签行 */
.tags-row {
  display: flex;
  flex-wrap: wrap;
  margin-bottom: 20rpx;
}

.tag {
  padding: 6rpx 18rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  margin-right: 12rpx;
  margin-bottom: 8rpx;
}

.tag-grade {
  background-color: #e6fffb;
  color: #13c2c2;
}

.tag-difficulty {
  background-color: #f6f0ff;
  color: #722ed1;
}

.tag-yi-ci-duo-yi {
  background-color: #fff7e6;
  color: #fa8c16;
}

.tag-zhong-kao-gao-pin {
  background-color: #fff0f6;
  color: #eb2f96;
}

.tag-duo-yin-zi {
  background-color: #f6ffed;
  color: #52c41a;
}

/* 错题统计条 */
.error-stats {
  display: flex;
  align-items: center;
  padding: 14rpx 20rpx;
  background-color: #f9f9f0;
  border-radius: 10rpx;
  margin-bottom: 20rpx;
  font-size: 24rpx;
}

.stats-orange {
  background-color: #fff8f0;
}

.stats-red {
  background-color: #fff1f0;
}

.stat-correct {
  color: #52c41a;
}

.stat-divider {
  color: #d9d9d9;
  margin: 0 16rpx;
}

.stat-wrong {
  color: #ff4d4f;
}

.stat-diff {
  color: #999;
  margin-left: 16rpx;
}

/* 卡片操作 */
.card-actions {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 18rpx;
  border-top: 1rpx dashed #e8e8e8;
}

.action-link {
  font-size: 26rpx;
  color: #999;
}

.action-link.primary {
  color: #667eea;
  font-weight: bold;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 150rpx 50rpx;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 30rpx;
}

.empty-text {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.empty-hint {
  font-size: 28rpx;
  color: #999;
}
