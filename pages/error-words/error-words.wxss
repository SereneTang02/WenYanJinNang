/* pages/error-words/error-words.wxss */
page {
  background: #f0f2f5;
}

.container {
  padding: 0 0 40rpx;
}

/* ===== Hero 头部区 ===== */
.hero-card {
  background: linear-gradient(160deg, #ff6b6b 0%, #ee5a6f 50%, #d94a5a 100%);
  padding: 50rpx 36rpx 40rpx;
  color: #fff;
  border-radius: 0 0 48rpx 48rpx;
  margin-bottom: 36rpx;
  position: relative;
  overflow: hidden;
}

.hero-card::after {
  content: '';
  position: absolute;
  top: -60rpx;
  right: -60rpx;
  width: 240rpx;
  height: 240rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.06);
}

.hero-top {
  display: flex;
  align-items: center;
  margin-bottom: 36rpx;
}

.hero-icon-wrap {
  width: 72rpx;
  height: 72rpx;
  border-radius: 18rpx;
  background: rgba(255, 255, 255, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
}

.hero-icon-text {
  font-size: 32rpx;
  font-weight: bold;
  color: #fff;
}

.hero-info {
  flex: 1;
}

.hero-title {
  font-size: 40rpx;
  font-weight: bold;
  margin-bottom: 6rpx;
}

.hero-sub {
  font-size: 26rpx;
  opacity: 0.75;
}

/* 统计行 */
.stats-row {
  display: flex;
  justify-content: space-around;
  align-items: center;
  background: rgba(255, 255, 255, 0.15);
  border-radius: 16rpx;
  padding: 24rpx 0;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.stat-num {
  font-size: 48rpx;
  font-weight: bold;
  margin-bottom: 6rpx;
}

.stat-label {
  font-size: 22rpx;
  opacity: 0.8;
}

.stat-divider {
  width: 1rpx;
  height: 50rpx;
  background: rgba(255, 255, 255, 0.2);
}

/* ===== 操作按钮区 ===== */
.action-bar {
  padding: 0 24rpx;
  margin-bottom: 36rpx;
}

.action-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx 28rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.action-card:active {
  transform: scale(0.98);
  opacity: 0.9;
}

.action-left {
  display: flex;
  align-items: center;
}

.action-icon-wrap {
  width: 72rpx;
  height: 72rpx;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
}

.action-icon-text {
  font-size: 32rpx;
  font-weight: bold;
  color: #fff;
}

.practice-bg {
  background: linear-gradient(135deg, #667eea, #764ba2);
}

.focus-bg {
  background: linear-gradient(135deg, #ff6b6b, #ee5a6f);
}

.action-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 4rpx;
}

.action-desc {
  font-size: 22rpx;
  color: #999;
}

.action-arrow {
  font-size: 32rpx;
  color: #ccc;
}

/* ===== 段落标题 ===== */
.section-label {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  padding: 0 36rpx;
  margin-bottom: 20rpx;
}

/* ===== 词卡列表 ===== */
.word-list {
  flex: 1;
  height: calc(100vh - 680rpx);
}

.word-list-inner {
  padding: 0 24rpx;
}

.word-card {
  background-color: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
  position: relative;
  transition: all 0.3s;
  border-left: 8rpx solid transparent;
  box-sizing: border-box;
}

.word-card:active {
  transform: scale(0.98);
  opacity: 0.9;
}

/* 词卡颜色等级 */
.card-white {
  background-color: #fff;
  border-left-color: #e8e8e8;
}

.card-orange {
  background-color: #fff8f0;
  border-left-color: #fa8c16;
}

.card-red {
  background-color: #fff1f0;
  border-left-color: #ff4d4f;
}

/* 第一行：词 + 词性 + 徽章 */
.word-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 20rpx;
}

.word-title {
  display: flex;
  align-items: center;
}

.word-text {
  font-size: 48rpx;
  font-weight: bold;
  color: #333;
  margin-right: 16rpx;
}

.category-tag {
  font-size: 22rpx;
  color: #666;
  background-color: #f0f0f0;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

/* 状态徽章 */
.error-badge {
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  flex-shrink: 0;
}

.badge-white {
  background-color: rgba(250, 173, 20, 0.1);
}

.badge-white .badge-text {
  color: #faad14;
}

.badge-orange {
  background-color: rgba(250, 140, 22, 0.12);
}

.badge-orange .badge-text {
  color: #fa8c16;
  font-weight: bold;
}

.badge-red {
  background-color: rgba(255, 77, 79, 0.12);
}

.badge-red .badge-text {
  color: #ff4d4f;
  font-weight: bold;
}

.badge-text {
  font-size: 24rpx;
}

/* 标签行 */
.tags-row {
  display: flex;
  flex-wrap: wrap;
  margin-bottom: 20rpx;
}

.tag {
  padding: 6rpx 18rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  margin-right: 12rpx;
  margin-bottom: 8rpx;
}

.tag-grade {
  background-color: #e6fffb;
  color: #13c2c2;
}

.tag-difficulty {
  background-color: #f6f0ff;
  color: #722ed1;
}

.tag-yi-ci-duo-yi {
  background-color: #fff7e6;
  color: #fa8c16;
}

.tag-zhong-kao-gao-pin {
  background-color: #fff0f6;
  color: #eb2f96;
}

.tag-duo-yin-zi {
  background-color: #f6ffed;
  color: #52c41a;
}

/* 错题统计条 */
.error-stats {
  display: flex;
  align-items: center;
  padding: 14rpx 20rpx;
  background-color: #f9f9f9;
  border-radius: 12rpx;
  margin-bottom: 20rpx;
  font-size: 24rpx;
}

.stats-orange {
  background-color: #fff8f0;
}

.stats-red {
  background-color: #fff1f0;
}

.stat-correct {
  color: #52c41a;
}

.stats-sep {
  color: #d9d9d9;
  margin: 0 16rpx;
}

.stat-wrong {
  color: #ff4d4f;
}

.stat-diff {
  color: #999;
  margin-left: 16rpx;
}

/* 卡片操作 */
.card-actions {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 18rpx;
  border-top: 1rpx dashed #e8e8e8;
}

.action-link {
  font-size: 26rpx;
  color: #999;
}

.action-link.primary {
  color: #667eea;
  font-weight: bold;
}

/* ===== 空状态 ===== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 150rpx 50rpx;
}

.empty-icon-wrap {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #52c41a, #73d13d);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 30rpx;
}

.empty-icon-text {
  font-size: 48rpx;
  font-weight: bold;
  color: #fff;
}

.empty-text {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.empty-hint {
  font-size: 28rpx;
  color: #999;
}
