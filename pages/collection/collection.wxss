/* pages/collection/collection.wxss */
.header-card {
  text-align: center;
  background: linear-gradient(135deg, #FFD700 0%, #FFA500 100%);
  color: white;
  padding: 40rpx 30rpx;
}

.header-icon {
  font-size: 72rpx;
  margin-bottom: 16rpx;
}

.header-title {
  font-size: 42rpx;
  font-weight: bold;
  margin-bottom: 12rpx;
}

.header-count {
  font-size: 26rpx;
  opacity: 0.9;
}

.action-bar {
  margin-top: 20rpx;
}

.empty-state {
  text-align: center;
  padding: 120rpx 40rpx;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 30rpx;
  opacity: 0.3;
}

.empty-text {
  font-size: 32rpx;
  color: #666;
  margin-bottom: 16rpx;
}

.empty-hint {
  font-size: 26rpx;
  color: #999;
  line-height: 1.6;
}

.words-list {
  margin-top: 20rpx;
}

.word-item {
  margin-bottom: 20rpx;
  padding: 0;
  overflow: hidden;
}

.word-main {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
}

.word-left {
  flex: 1;
}

.word-text {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}

.word-pinyin {
  font-size: 26rpx;
  color: #666;
}

.word-right {
  text-align: right;
}

.word-category {
  display: inline-block;
  padding: 6rpx 16rpx;
  background-color: #4A90E2;
  color: white;
  border-radius: 16rpx;
  font-size: 22rpx;
  margin-bottom: 8rpx;
}

.meanings-count {
  font-size: 24rpx;
  color: #999;
}

.word-actions {
  border-top: 1rpx solid #f0f0f0;
  padding: 16rpx 30rpx;
  display: flex;
  justify-content: flex-end;
}

.action-btn {
  font-size: 26rpx;
  color: #F5222D;
  padding: 8rpx 20rpx;
}
