/* pages/collection/collection.wxss - 温润古典·书卷风 */
page {
  background: #FBF6F0;
}

.container {
  padding: 0 0 40rpx;
}

/* ===== Hero 头部区 ===== */
.hero-card {
  background: linear-gradient(180deg, #C4882E 0%, #E8D5B8 60%, #FBF6F0 100%);
  padding: 50rpx 36rpx 40rpx;
  color: #fff;
  border-radius: 0 0 48rpx 48rpx;
  margin-bottom: 36rpx;
  position: relative;
  overflow: hidden;
}

.hero-card::after {
  content: '';
  position: absolute;
  top: -60rpx;
  right: -60rpx;
  width: 240rpx;
  height: 240rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(255, 255, 255, 0.12) 0%, transparent 70%);
}

.hero-top {
  display: flex;
  align-items: center;
  margin-bottom: 36rpx;
}

.hero-icon-wrap {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.2);
  border: 2rpx solid rgba(255, 255, 255, 0.35);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
}

.hero-icon-text {
  font-size: 32rpx;
  font-weight: bold;
  color: #fff;
}

.hero-info {
  flex: 1;
}

.hero-title {
  font-size: 40rpx;
  font-weight: bold;
  margin-bottom: 6rpx;
}

.hero-sub {
  font-size: 26rpx;
  opacity: 0.85;
}

/* 统计行 */
.stats-row {
  display: flex;
  justify-content: center;
  align-items: center;
  background: rgba(255, 255, 255, 0.3);
  border: 1rpx solid rgba(255, 255, 255, 0.25);
  border-radius: 20rpx;
  padding: 24rpx 0;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-num {
  font-size: 48rpx;
  font-weight: bold;
  margin-bottom: 6rpx;
}

.stat-label {
  font-size: 22rpx;
  opacity: 0.85;
}

/* ===== 操作按钮区 ===== */
.action-bar {
  padding: 0 24rpx;
  margin-bottom: 36rpx;
}

.action-card {
  background: rgba(255, 255, 255, 0.88);
  border: 1rpx solid rgba(200, 175, 140, 0.18);
  border-radius: 24rpx;
  padding: 28rpx 32rpx;
  box-shadow: 0 4rpx 20rpx rgba(166, 138, 100, 0.08);
  display: flex;
  align-items: center;
  justify-content: space-between;
  transition: all 0.3s;
}

.action-card:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 10rpx rgba(166, 138, 100, 0.12);
}

.action-left {
  display: flex;
  align-items: center;
}

.action-icon-wrap {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
}

.action-icon-text {
  font-size: 32rpx;
  font-weight: bold;
}

.review-bg {
  background: rgba(200, 168, 124, 0.08);
  border: 2rpx solid #C4882E;
}

.review-bg .action-icon-text {
  color: #C4882E;
}

.action-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #1A1008;
  margin-bottom: 4rpx;
}

.action-desc {
  font-size: 22rpx;
  color: #5C4D3E;
}

.action-right {
  margin-left: 24rpx;
}

.action-circle {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #C4882E, #E8C36A);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 6rpx 16rpx rgba(200, 168, 124, 0.25);
}

.action-circle-text {
  color: #fff;
  font-size: 26rpx;
  font-weight: bold;
}

/* ===== 段落标题 ===== */
.section-label {
  font-size: 32rpx;
  font-weight: bold;
  color: #1A1008;
  padding: 0 36rpx;
  margin-bottom: 20rpx;
}

/* ===== 词卡列表 ===== */
.words-list {
  padding: 0 24rpx;
}

.word-card {
  background: rgba(255, 255, 255, 0.88);
  border: 1rpx solid rgba(200, 175, 140, 0.18);
  border-radius: 24rpx;
  padding: 0;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(166, 138, 100, 0.08);
  overflow: hidden;
  transition: all 0.3s;
}

.word-card:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 10rpx rgba(166, 138, 100, 0.12);
}

.word-main {
  padding: 30rpx;
}

/* 第一行：词 + 词性 */
.word-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 12rpx;
}

.word-title {
  display: flex;
  align-items: center;
}

.word-text {
  font-size: 48rpx;
  font-weight: bold;
  color: #1A1008;
  margin-right: 16rpx;
}

.category-tag {
  font-size: 22rpx;
  color: #C4882E;
  background-color: rgba(200, 168, 124, 0.1);
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

/* 拼音 */
.word-pinyin {
  font-size: 26rpx;
  color: #4A3C30;
  margin-bottom: 12rpx;
}

/* 义项数 */
.meanings-count {
  font-size: 24rpx;
  color: #5C4D3E;
}

/* 操作行 */
.card-actions {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 18rpx 30rpx;
  border-top: 1rpx solid rgba(200, 175, 140, 0.15);
}

.action-link {
  font-size: 26rpx;
  color: #5C4D3E;
}

.action-link.danger {
  color: #E05A47;
}

/* ===== 空状态 ===== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 150rpx 50rpx;
}

.empty-icon-wrap {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: rgba(200, 168, 124, 0.08);
  border: 2rpx solid #C4882E;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 30rpx;
}

.empty-icon-text {
  font-size: 48rpx;
  font-weight: bold;
  color: #C4882E;
}

.empty-text {
  font-size: 36rpx;
  font-weight: bold;
  color: #1A1008;
  margin-bottom: 20rpx;
}

.empty-hint {
  font-size: 28rpx;
  color: #5C4D3E;
  text-align: center;
  line-height: 1.6;
}
