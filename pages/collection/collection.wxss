/* pages/collection/collection.wxss */
page {
  background: #f0f2f5;
}

.container {
  padding: 0 0 40rpx;
}

/* ===== Hero 头部区 ===== */
.hero-card {
  background: linear-gradient(160deg, #FFD700 0%, #FFA500 50%, #E69500 100%);
  padding: 50rpx 36rpx 40rpx;
  color: #fff;
  border-radius: 0 0 48rpx 48rpx;
  margin-bottom: 36rpx;
  position: relative;
  overflow: hidden;
}

.hero-card::after {
  content: '';
  position: absolute;
  top: -60rpx;
  right: -60rpx;
  width: 240rpx;
  height: 240rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.06);
}

.hero-top {
  display: flex;
  align-items: center;
  margin-bottom: 36rpx;
}

.hero-icon-wrap {
  width: 72rpx;
  height: 72rpx;
  border-radius: 18rpx;
  background: rgba(255, 255, 255, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
}

.hero-icon-text {
  font-size: 32rpx;
  font-weight: bold;
  color: #fff;
}

.hero-info {
  flex: 1;
}

.hero-title {
  font-size: 40rpx;
  font-weight: bold;
  margin-bottom: 6rpx;
}

.hero-sub {
  font-size: 26rpx;
  opacity: 0.75;
}

/* 统计行 */
.stats-row {
  display: flex;
  justify-content: center;
  align-items: center;
  background: rgba(255, 255, 255, 0.15);
  border-radius: 16rpx;
  padding: 24rpx 0;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-num {
  font-size: 48rpx;
  font-weight: bold;
  margin-bottom: 6rpx;
}

.stat-label {
  font-size: 22rpx;
  opacity: 0.8;
}

/* ===== 操作按钮区 ===== */
.action-bar {
  padding: 0 24rpx;
  margin-bottom: 36rpx;
}

.action-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx 32rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.action-card:active {
  transform: scale(0.98);
  opacity: 0.9;
}

.action-left {
  display: flex;
  align-items: center;
}

.action-icon-wrap {
  width: 72rpx;
  height: 72rpx;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
}

.action-icon-text {
  font-size: 32rpx;
  font-weight: bold;
  color: #fff;
}

.review-bg {
  background: linear-gradient(135deg, #f6d365, #fda085);
}

.action-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 4rpx;
}

.action-desc {
  font-size: 22rpx;
  color: #999;
}

.action-right {
  margin-left: 24rpx;
}

.action-circle {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #FFD700, #FFA500);
  display: flex;
  align-items: center;
  justify-content: center;
}

.action-circle-text {
  color: #fff;
  font-size: 26rpx;
  font-weight: bold;
}

/* ===== 段落标题 ===== */
.section-label {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  padding: 0 36rpx;
  margin-bottom: 20rpx;
}

/* ===== 词卡列表 ===== */
.words-list {
  padding: 0 24rpx;
}

.word-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 0;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
  overflow: hidden;
}

.word-card:active {
  transform: scale(0.98);
  opacity: 0.9;
}

.word-main {
  padding: 30rpx;
}

/* 第一行：词 + 词性 */
.word-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 12rpx;
}

.word-title {
  display: flex;
  align-items: center;
}

.word-text {
  font-size: 48rpx;
  font-weight: bold;
  color: #333;
  margin-right: 16rpx;
}

.category-tag {
  font-size: 22rpx;
  color: #666;
  background-color: #f0f0f0;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

/* 拼音 */
.word-pinyin {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 12rpx;
}

/* 义项数 */
.meanings-count {
  font-size: 24rpx;
  color: #999;
}

/* 操作行 */
.card-actions {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 18rpx 30rpx;
  border-top: 1rpx dashed #e8e8e8;
}

.action-link {
  font-size: 26rpx;
  color: #999;
}

.action-link.danger {
  color: #ff4d4f;
}

/* ===== 空状态 ===== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 150rpx 50rpx;
}

.empty-icon-wrap {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #FFD700, #FFA500);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 30rpx;
}

.empty-icon-text {
  font-size: 48rpx;
  font-weight: bold;
  color: #fff;
}

.empty-text {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.empty-hint {
  font-size: 28rpx;
  color: #999;
  text-align: center;
  line-height: 1.6;
}
