/* pages/student-info/student-info.wxss */
.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #f0f8ff 0%, #fff 100%);
  padding: 60rpx 40rpx 40rpx;
}

/* 顶部标题 */
.header {
  text-align: center;
  margin-bottom: 60rpx;
}

.header-icon {
  font-size: 100rpx;
  margin-bottom: 20rpx;
}

.title {
  font-size: 48rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 15rpx;
}

.subtitle {
  font-size: 26rpx;
  color: #999;
}

/* 表单容器 */
.form-container {
  background: #fff;
  border-radius: 24rpx;
  padding: 40rpx 30rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
  margin-bottom: 40rpx;
}

/* 表单项 */
.form-item {
  margin-bottom: 40rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

.form-label {
  display: flex;
  align-items: center;
  margin-bottom: 15rpx;
}

.label-text {
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
}

.required-star {
  color: #ff4d4f;
  margin-left: 5rpx;
  font-size: 32rpx;
}

.optional-tag {
  font-size: 22rpx;
  color: #999;
  background: #f5f5f5;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  margin-left: 10rpx;
}

/* 选择器 */
.picker {
  width: 100%;
}

.picker-content {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 90rpx;
  padding: 0 25rpx;
  background: #f8f9fa;
  border-radius: 16rpx;
  border: 2rpx solid transparent;
  transition: all 0.3s;
}

.picker-value {
  font-size: 28rpx;
  color: #333;
}

.picker-content:active {
  border-color: #4facfe;
  background: #f0f8ff;
}

.picker-arrow {
  font-size: 20rpx;
  color: #999;
}

/* 输入框 */
.input {
  height: 90rpx;
  padding: 0 25rpx;
  background: #f8f9fa;
  border-radius: 16rpx;
  font-size: 28rpx;
  border: 2rpx solid transparent;
  transition: all 0.3s;
}

.input:focus {
  border-color: #4facfe;
  background: #f0f8ff;
}

/* 提示信息 */
.tips {
  display: flex;
  align-items: flex-start;
  padding: 25rpx;
  background: rgba(79, 172, 254, 0.1);
  border-radius: 16rpx;
  border-left: 6rpx solid #4facfe;
  margin-bottom: 60rpx;
}

.tips-icon {
  font-size: 36rpx;
  margin-right: 15rpx;
  flex-shrink: 0;
}

.tips-text {
  flex: 1;
  font-size: 24rpx;
  color: #666;
  line-height: 1.6;
}

/* 提交按钮 */
.submit-section {
  margin-top: auto;
}

.submit-button {
  width: 100%;
  height: 100rpx;
  background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);
  border-radius: 50rpx;
  font-size: 34rpx;
  font-weight: bold;
  color: #fff;
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(79, 172, 254, 0.4);
  transition: all 0.3s;
}

.submit-button:not(.loading):active {
  transform: translateY(-4rpx);
  box-shadow: 0 12rpx 32rpx rgba(79, 172, 254, 0.5);
}

.submit-button.loading {
  opacity: 0.7;
}
