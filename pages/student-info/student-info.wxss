/* pages/student-info/student-info.wxss */
page {
  background: #f0f2f5;
}

.container {
  padding: 0 0 60rpx;
  min-height: 100vh;
}

/* ===== 顶部英雄卡片 ===== */
.hero-card {
  background: linear-gradient(160deg, #4A90E2 0%, #357ABD 50%, #2E6BA6 100%);
  padding: 50rpx 36rpx 44rpx;
  color: #fff;
  border-radius: 0 0 48rpx 48rpx;
  margin-bottom: 36rpx;
  text-align: center;
  position: relative;
  overflow: hidden;
}

.hero-card::after {
  content: '';
  position: absolute;
  top: -50rpx;
  right: -50rpx;
  width: 220rpx;
  height: 220rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.06);
}

.hero-icon-wrap {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.18);
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 16rpx;
}

.hero-icon-text {
  font-size: 40rpx;
  font-weight: bold;
  color: #fff;
}

.hero-title {
  font-size: 40rpx;
  font-weight: bold;
  margin-bottom: 8rpx;
}

.hero-sub {
  font-size: 26rpx;
  opacity: 0.75;
}

/* ===== 表单卡片 ===== */
.form-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 36rpx 30rpx;
  margin: 0 24rpx 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.form-item {
  margin-bottom: 32rpx;
  padding-bottom: 32rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.form-item.last {
  margin-bottom: 0;
  padding-bottom: 0;
  border-bottom: none;
}

.form-label {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.label-text {
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
}

.required-star {
  color: #f5576c;
  margin-left: 6rpx;
  font-size: 32rpx;
}

.optional-tag {
  font-size: 22rpx;
  color: #999;
  background: #f5f5f5;
  padding: 4rpx 14rpx;
  border-radius: 8rpx;
  margin-left: 12rpx;
}

/* 选择器 */
.picker-content {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 88rpx;
  padding: 0 24rpx;
  background: #f6f7f9;
  border-radius: 16rpx;
  border: 2rpx solid transparent;
}

.picker-content:active {
  border-color: #4A90E2;
  background: #f0f5ff;
}

.picker-value {
  font-size: 28rpx;
  color: #333;
}

.picker-value.placeholder {
  color: #bbb;
}

.picker-arrow {
  font-size: 20rpx;
  color: #bbb;
}

/* 输入框 */
.form-input {
  height: 88rpx;
  padding: 0 24rpx;
  background: #f6f7f9;
  border-radius: 16rpx;
  font-size: 28rpx;
  border: 2rpx solid transparent;
}

.form-input:focus {
  border-color: #4A90E2;
  background: #f0f5ff;
}

/* ===== 提示 ===== */
.tip-card {
  display: flex;
  align-items: center;
  margin: 0 24rpx 36rpx;
  padding: 22rpx 24rpx;
  background: rgba(74, 144, 226, 0.08);
  border-radius: 16rpx;
}

.tip-icon-wrap {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  background: rgba(74, 144, 226, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 12rpx;
  flex-shrink: 0;
}

.tip-icon-text {
  font-size: 22rpx;
  font-weight: bold;
  color: #4A90E2;
}

.tip-text {
  font-size: 24rpx;
  color: #4A90E2;
  line-height: 1.5;
}

/* ===== 提交按钮 ===== */
.submit-area {
  padding: 0 24rpx;
}

.submit-btn {
  width: 100%;
  height: 92rpx;
  line-height: 92rpx;
  background: linear-gradient(135deg, #4A90E2, #357ABD);
  color: #fff;
  border-radius: 46rpx;
  font-size: 34rpx;
  font-weight: bold;
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(74, 144, 226, 0.35);
  text-align: center;
  padding: 0;
}

.submit-btn::after {
  border: none;
}

.submit-btn:active:not(.disabled) {
  opacity: 0.85;
}

.submit-btn.disabled {
  opacity: 0.6;
}
