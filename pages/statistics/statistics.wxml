<!--pages/statistics/statistics.wxml-->
<view class="container">
  <!-- 顶部栏：核心进度 -->
  <view class="hero-card">
    <view class="hero-title">学习统计</view>
    <view class="hero-sub">坚持学习，积少成多</view>

    <view class="progress-ring-area">
      <view class="progress-ring">
        <view class="progress-ring-inner">
          <text class="ring-num">{{stats.progress}}%</text>
          <text class="ring-label">完成度</text>
        </view>
      </view>
      <view class="progress-detail">
        已学习 <text class="highlight">{{stats.totalStudied}}</text> / {{stats.totalWords}} 个实词
      </view>
    </view>
  </view>

  <!-- 核心数据卡片 -->
  <view class="section-label">核心数据</view>
  <view class="data-grid">
    <view class="data-card">
      <view class="data-icon-wrap icon-purple">
        <text class="data-icon-text">学</text>
      </view>
      <view class="data-value">{{stats.totalAttempts}}</view>
      <view class="data-label">学习次数</view>
    </view>
    <view class="data-card">
      <view class="data-icon-wrap icon-green">
        <text class="data-icon-text">对</text>
      </view>
      <view class="data-value color-green">{{stats.correctCount}}</view>
      <view class="data-label">正确次数</view>
    </view>
    <view class="data-card">
      <view class="data-icon-wrap icon-blue">
        <text class="data-icon-text">率</text>
      </view>
      <view class="data-value color-blue">{{stats.accuracy}}%</view>
      <view class="data-label">正确率</view>
    </view>
    <view class="data-card">
      <view class="data-icon-wrap icon-red">
        <text class="data-icon-text">错</text>
      </view>
      <view class="data-value color-red">{{collectedCount}}</view>
      <view class="data-label">错题数量</view>
    </view>
  </view>

  <!-- 最近7天柱状图 -->
  <view class="section-label">最近 7 天</view>
  <view class="chart-card">
    <view class="chart-bar-area">
      <view class="chart-col" wx:for="{{recentDays}}" wx:key="date">
        <text class="chart-count">{{item.count}}</text>
        <view class="chart-bar-bg">
          <view class="chart-bar-fill {{item.count > 0 ? 'active' : ''}}" style="height: {{item.percent}}%"></view>
        </view>
        <text class="chart-date">{{item.date}}</text>
      </view>
    </view>
    <view class="chart-summary">最近 {{stats.recentDays}} 天有学习记录</view>
  </view>

  <!-- 鼓励卡片 -->
  <view class="encourage-card">
    <view class="encourage-left">
      <view class="encourage-icon">{{encourageData.icon}}</view>
    </view>
    <view class="encourage-right">
      <view class="encourage-text">{{encourageData.text}}</view>
    </view>
  </view>

  <!-- 危险操作 -->
  <view class="danger-area">
    <button class="danger-btn" bindtap="clearData">清空学习数据</button>
  </view>
</view>
