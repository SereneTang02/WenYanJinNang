/* pages/word-list/word-list.wxss - 温润古典·书卷风 */
page {
  background: #FBF6F0;
}

.container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  padding: 0;
}

/* ===== Hero 头部区 ===== */
.hero-card {
  background: linear-gradient(180deg, #E8D5B8 0%, #F2E8D6 60%, #FBF6F0 100%);
  padding: 50rpx 36rpx 64rpx;
  color: #1A1008;
  border-radius: 0 0 48rpx 48rpx;
  position: relative;
  overflow: hidden;
}

.hero-card::after {
  content: '';
  position: absolute;
  top: -60rpx;
  right: -60rpx;
  width: 240rpx;
  height: 240rpx;
  border-radius: 50%;
  background: rgba(200, 168, 124, 0.1);
}

.hero-top {
  display: flex;
  align-items: center;
  margin-bottom: 36rpx;
}

.hero-icon-wrap {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: rgba(200, 168, 124, 0.08);
  border: 2rpx solid #C4882E;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
}

.hero-icon-text {
  font-size: 32rpx;
  font-weight: bold;
  color: #C4882E;
}

.hero-info {
  flex: 1;
}

.hero-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #1A1008;
  margin-bottom: 6rpx;
}

.hero-sub {
  font-size: 26rpx;
  color: #4A3C30;
}

/* 统计行 */
.stats-row {
  display: flex;
  justify-content: space-around;
  align-items: center;
  background: rgba(255, 255, 255, 0.88);
  border: 1rpx solid rgba(200, 175, 140, 0.18);
  border-radius: 20rpx;
  padding: 24rpx 0;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.stat-num {
  font-size: 48rpx;
  font-weight: bold;
  color: #C4882E;
  margin-bottom: 6rpx;
}

.stat-label {
  font-size: 22rpx;
  color: #4A3C30;
}

.stat-divider {
  width: 1rpx;
  height: 50rpx;
  background: rgba(200, 175, 140, 0.3);
}

/* ===== 筛选区 ===== */
.filter-card {
  background: rgba(255, 255, 255, 0.88);
  border: 1rpx solid rgba(200, 175, 140, 0.18);
  border-radius: 24rpx;
  padding: 24rpx;
  margin: -24rpx 24rpx 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(166, 138, 100, 0.08);
  position: relative;
  z-index: 1;
}

/* 搜索框 */
.search-bar {
  position: relative;
  margin-bottom: 20rpx;
}

.search-input {
  width: 100%;
  height: 72rpx;
  padding: 0 100rpx 0 30rpx;
  background-color: #F5F0E8;
  border-radius: 36rpx;
  font-size: 28rpx;
  color: #1A1008;
  box-sizing: border-box;
}

.search-icon {
  position: absolute;
  right: 30rpx;
  top: 50%;
  transform: translateY(-50%);
  font-size: 32rpx;
  color: #5C4D3E;
}

/* 筛选栏 */
.filter-bar {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
}

.filter-item {
  display: flex;
  align-items: center;
  margin-right: 20rpx;
  margin-bottom: 10rpx;
}

.filter-label {
  font-size: 26rpx;
  color: #4A3C30;
  margin-right: 10rpx;
}

.picker-button {
  padding: 10rpx 20rpx;
  background-color: #F5F0E8;
  border-radius: 20rpx;
  font-size: 26rpx;
  color: #1A1008;
}

.arrow {
  margin-left: 5rpx;
  font-size: 20rpx;
  color: #5C4D3E;
}

.reset-button {
  padding: 10rpx 30rpx;
  background-color: #F5F0E8;
  color: #5C4D3E;
  border-radius: 20rpx;
  font-size: 26rpx;
  margin-bottom: 10rpx;
}

.reset-button:active {
  background-color: #EDE5D8;
}

/* 年级信息 */
.grade-info {
  padding-top: 14rpx;
  border-top: 1rpx solid rgba(200, 175, 140, 0.18);
  margin-top: 10rpx;
}

.grade-tag {
  font-size: 24rpx;
  color: #C4882E;
}

/* 筛选计数 */
.filter-count {
  padding-top: 14rpx;
  border-top: 1rpx solid rgba(200, 175, 140, 0.18);
  margin-top: 10rpx;
  text-align: center;
}

.filter-count text {
  font-size: 24rpx;
  color: #C4882E;
  font-weight: 500;
}

/* ===== 段落标题 ===== */
.section-label {
  font-size: 32rpx;
  font-weight: bold;
  color: #1A1008;
  padding: 36rpx 36rpx 20rpx;
}

/* ===== 词卡列表 ===== */
.word-list {
  flex: 1;
}

.word-list-inner {
  padding: 0 24rpx 40rpx;
}

.word-card {
  background-color: rgba(255, 255, 255, 0.88);
  border: 1rpx solid rgba(200, 175, 140, 0.18);
  border-radius: 24rpx;
  padding: 30rpx 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(166, 138, 100, 0.08);
  position: relative;
  transition: all 0.3s;
  border-left: 8rpx solid transparent;
  box-sizing: border-box;
}

.word-card:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 10rpx rgba(166, 138, 100, 0.12);
}

/* 词卡颜色等级 */
.card-white {
  background-color: rgba(255, 255, 255, 0.88);
  border-left-color: transparent;
}

.card-orange {
  background-color: rgba(200, 168, 124, 0.06);
  border-left-color: #C4882E;
}

.card-red {
  background-color: rgba(201, 107, 92, 0.06);
  border-left-color: #E05A47;
}

/* 第一行：词 + 词性 + 徽章 */
.word-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 20rpx;
}

.word-title {
  display: flex;
  align-items: center;
}

.word-text {
  font-size: 48rpx;
  font-weight: bold;
  color: #1A1008;
  margin-right: 16rpx;
}

.category-tag {
  font-size: 22rpx;
  color: #C4882E;
  background-color: rgba(200, 168, 124, 0.12);
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

/* 状态徽章 */
.error-badge {
  padding: 6rpx 16rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
}

.badge-orange {
  background-color: rgba(200, 168, 124, 0.12);
}

.badge-orange .badge-text {
  color: #C4882E;
  font-weight: bold;
}

.badge-red {
  background-color: rgba(201, 107, 92, 0.1);
}

.badge-red .badge-text {
  color: #E05A47;
  font-weight: bold;
}

.badge-text {
  font-size: 24rpx;
}

/* 标签行 */
.tags-row {
  display: flex;
  flex-wrap: wrap;
  margin-bottom: 15rpx;
}

.tag {
  padding: 6rpx 18rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  margin-right: 12rpx;
  margin-bottom: 8rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  line-height: 1;
}

.tag-grade {
  background-color: rgba(123, 175, 110, 0.1);
  color: #4CAF50;
}

.tag-match {
  background-color: rgba(201, 107, 92, 0.08);
  color: #E05A47;
  font-weight: 500;
}

.tag-difficulty {
  background-color: rgba(107, 152, 184, 0.1);
  color: #3A8FC2;
}

.tag-yi-ci-duo-yi {
  background-color: rgba(200, 168, 124, 0.12);
  color: #C4882E;
}

.tag-zhong-kao-gao-pin {
  background-color: rgba(201, 107, 92, 0.08);
  color: #B85C4A;
}

.tag-duo-yin-zi {
  background-color: rgba(123, 175, 110, 0.1);
  color: #4CAF50;
}

/* 义项数量 */
.meanings-count {
  font-size: 24rpx;
  color: #5C4D3E;
}

/* ===== 空状态 ===== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}

.empty-icon-wrap {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: rgba(200, 168, 124, 0.08);
  border: 2rpx solid #C4882E;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 30rpx;
}

.empty-icon-text {
  font-size: 48rpx;
  font-weight: bold;
  color: #C4882E;
}

.empty-text {
  font-size: 32rpx;
  font-weight: bold;
  color: #1A1008;
  margin-bottom: 20rpx;
}

.empty-hint {
  font-size: 26rpx;
  color: #5C4D3E;
}
