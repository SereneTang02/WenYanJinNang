/* pages/word-list/word-list.wxss */
page {
  background: #f0f2f5;
}

.container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  padding: 0;
}

/* ===== Hero 头部区 ===== */
.hero-card {
  background: linear-gradient(160deg, #4A90E2 0%, #357ABD 50%, #2E6BA6 100%);
  padding: 50rpx 36rpx 64rpx;
  color: #fff;
  border-radius: 0 0 48rpx 48rpx;
  position: relative;
  overflow: hidden;
}

.hero-card::after {
  content: '';
  position: absolute;
  top: -60rpx;
  right: -60rpx;
  width: 240rpx;
  height: 240rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.06);
}

.hero-top {
  display: flex;
  align-items: center;
  margin-bottom: 36rpx;
}

.hero-icon-wrap {
  width: 72rpx;
  height: 72rpx;
  border-radius: 18rpx;
  background: rgba(255, 255, 255, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
}

.hero-icon-text {
  font-size: 32rpx;
  font-weight: bold;
  color: #fff;
}

.hero-info {
  flex: 1;
}

.hero-title {
  font-size: 40rpx;
  font-weight: bold;
  margin-bottom: 6rpx;
}

.hero-sub {
  font-size: 26rpx;
  opacity: 0.75;
}

/* 统计行 */
.stats-row {
  display: flex;
  justify-content: space-around;
  align-items: center;
  background: rgba(255, 255, 255, 0.15);
  border-radius: 16rpx;
  padding: 24rpx 0;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.stat-num {
  font-size: 48rpx;
  font-weight: bold;
  margin-bottom: 6rpx;
}

.stat-label {
  font-size: 22rpx;
  opacity: 0.8;
}

.stat-divider {
  width: 1rpx;
  height: 50rpx;
  background: rgba(255, 255, 255, 0.2);
}

/* ===== 筛选区 ===== */
.filter-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx;
  margin: -24rpx 24rpx 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
  position: relative;
  z-index: 1;
}

/* 搜索框 */
.search-bar {
  position: relative;
  margin-bottom: 20rpx;
}

.search-input {
  width: 100%;
  height: 70rpx;
  padding: 0 100rpx 0 30rpx;
  background-color: #f0f2f5;
  border-radius: 35rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.search-icon {
  position: absolute;
  right: 30rpx;
  top: 50%;
  transform: translateY(-50%);
  font-size: 32rpx;
}

/* 筛选栏 */
.filter-bar {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
}

.filter-item {
  display: flex;
  align-items: center;
  margin-right: 20rpx;
  margin-bottom: 10rpx;
}

.filter-label {
  font-size: 26rpx;
  color: #666;
  margin-right: 10rpx;
}

.picker-button {
  padding: 10rpx 20rpx;
  background-color: #f0f2f5;
  border-radius: 20rpx;
  font-size: 26rpx;
  color: #333;
}

.arrow {
  margin-left: 5rpx;
  font-size: 20rpx;
  color: #999;
}

.reset-button {
  padding: 10rpx 30rpx;
  background-color: #f0f2f5;
  color: #999;
  border-radius: 20rpx;
  font-size: 26rpx;
  margin-bottom: 10rpx;
}

.reset-button:active {
  background-color: #e8e8e8;
}

/* 年级信息 */
.grade-info {
  padding-top: 14rpx;
  border-top: 1rpx solid #f0f0f0;
  margin-top: 10rpx;
}

.grade-tag {
  font-size: 24rpx;
  color: #4A90E2;
}

/* 筛选计数 */
.filter-count {
  padding-top: 14rpx;
  border-top: 1rpx solid #f0f0f0;
  margin-top: 10rpx;
  text-align: center;
}

.filter-count text {
  font-size: 24rpx;
  color: #4A90E2;
  font-weight: 500;
}

/* ===== 段落标题 ===== */
.section-label {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  padding: 36rpx 36rpx 20rpx;
}

/* ===== 词卡列表 ===== */
.word-list {
  flex: 1;
}

.word-list-inner {
  padding: 0 24rpx 40rpx;
}

.word-card {
  background-color: #fff;
  border-radius: 20rpx;
  padding: 30rpx 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
  position: relative;
  transition: all 0.3s;
  border-left: 8rpx solid transparent;
  box-sizing: border-box;
}

.word-card:active {
  transform: scale(0.98);
  opacity: 0.9;
}

/* 词卡颜色等级 */
.card-white {
  background-color: #fff;
  border-left-color: transparent;
}

.card-orange {
  background-color: #fff8f0;
  border-left-color: #fa8c16;
}

.card-red {
  background-color: #fff1f0;
  border-left-color: #ff4d4f;
}

/* 第一行：词 + 词性 + 徽章 */
.word-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 20rpx;
}

.word-title {
  display: flex;
  align-items: center;
}

.word-text {
  font-size: 48rpx;
  font-weight: bold;
  color: #333;
  margin-right: 16rpx;
}

.category-tag {
  font-size: 22rpx;
  color: #666;
  background-color: #f0f0f0;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

/* 状态徽章 */
.error-badge {
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  flex-shrink: 0;
}

.badge-orange {
  background-color: rgba(250, 140, 22, 0.12);
}

.badge-orange .badge-text {
  color: #fa8c16;
  font-weight: bold;
}

.badge-red {
  background-color: rgba(255, 77, 79, 0.12);
}

.badge-red .badge-text {
  color: #ff4d4f;
  font-weight: bold;
}

.badge-text {
  font-size: 24rpx;
}

/* 标签行 */
.tags-row {
  display: flex;
  flex-wrap: wrap;
  margin-bottom: 15rpx;
}

.tag {
  padding: 6rpx 18rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  margin-right: 12rpx;
  margin-bottom: 8rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  line-height: 1;
}

.tag-grade {
  background-color: #e6fffb;
  color: #13c2c2;
}

.tag-match {
  background-color: #fff1f0;
  color: #ff4d4f;
  font-weight: 500;
}

.tag-difficulty {
  background-color: #f6f0ff;
  color: #722ed1;
}

.tag-yi-ci-duo-yi {
  background-color: #fff7e6;
  color: #fa8c16;
}

.tag-zhong-kao-gao-pin {
  background-color: #fff0f6;
  color: #eb2f96;
}

.tag-duo-yin-zi {
  background-color: #f6ffed;
  color: #52c41a;
}

/* 义项数量 */
.meanings-count {
  font-size: 24rpx;
  color: #999;
}

/* ===== 空状态 ===== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}

.empty-icon-wrap {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #4A90E2, #5BA3F5);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 30rpx;
}

.empty-icon-text {
  font-size: 48rpx;
  font-weight: bold;
  color: #fff;
}

.empty-text {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.empty-hint {
  font-size: 26rpx;
  color: #999;
}
