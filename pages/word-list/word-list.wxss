/* pages/word-list/word-list.wxss */
.container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background-color: #f5f5f5;
}

/* 筛选区域 */
.filter-section {
  background-color: #fff;
  padding: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

/* 搜索框 */
.search-bar {
  position: relative;
  margin-bottom: 20rpx;
}

.search-input {
  width: 100%;
  height: 70rpx;
  padding: 0 100rpx 0 30rpx;
  background-color: #f5f5f5;
  border-radius: 35rpx;
  font-size: 28rpx;
}

.search-icon {
  position: absolute;
  right: 30rpx;
  top: 50%;
  transform: translateY(-50%);
  font-size: 32rpx;
}

/* 筛选栏 */
.filter-bar {
  display: flex;
  align-items: center;
  padding: 10rpx 0;
  flex-wrap: wrap;
}

.filter-item {
  display: flex;
  align-items: center;
  margin-right: 20rpx;
  margin-bottom: 10rpx;
}

.filter-label {
  font-size: 26rpx;
  color: #666;
  margin-right: 10rpx;
}

.picker-button {
  padding: 10rpx 20rpx;
  background-color: #f5f5f5;
  border-radius: 20rpx;
  font-size: 26rpx;
  color: #333;
}

.arrow {
  margin-left: 5rpx;
  font-size: 20rpx;
  color: #999;
}

.reset-button {
  padding: 10rpx 30rpx;
  background-color: #ff6b6b;
  color: #fff;
  border-radius: 20rpx;
  font-size: 26rpx;
  margin-bottom: 10rpx;
}

/* 统计栏 */
.stats-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 15rpx 0;
  border-top: 1rpx solid #eee;
  margin-top: 10rpx;
}

.stats-text {
  font-size: 24rpx;
  color: #999;
}

.grade-tag {
  font-size: 24rpx;
  color: #1890ff;
  text-decoration: underline;
}

/* 词卡列表 */
.word-list {
  flex: 1;
  padding: 20rpx;
}

.word-card {
  background-color: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
  position: relative;
  transition: all 0.3s;
  border-left: 8rpx solid transparent;
}

/* 词卡颜色等级 */
.card-white {
  background-color: #fff;
  border-left-color: transparent;
}

.card-orange {
  background-color: #fff8f0;
  border-left-color: #fa8c16;
}

.card-red {
  background-color: #fff1f0;
  border-left-color: #ff4d4f;
}

/* 第一行：词 + 词性 + 徽章 */
.word-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 20rpx;
}

.word-title {
  display: flex;
  align-items: center;
}

.word-text {
  font-size: 48rpx;
  font-weight: bold;
  color: #333;
  margin-right: 16rpx;
}

.category-tag {
  font-size: 22rpx;
  color: #666;
  background-color: #f0f0f0;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

/* 状态徽章 */
.error-badge {
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  flex-shrink: 0;
}

.badge-orange {
  background-color: rgba(250, 140, 22, 0.12);
}

.badge-orange .badge-text {
  color: #fa8c16;
  font-weight: bold;
}

.badge-red {
  background-color: rgba(255, 77, 79, 0.12);
}

.badge-red .badge-text {
  color: #ff4d4f;
  font-weight: bold;
}

.badge-text {
  font-size: 24rpx;
}

/* 标签行 */
.tags-row {
  display: flex;
  flex-wrap: wrap;
  margin-bottom: 15rpx;
}

.tag {
  padding: 6rpx 18rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  margin-right: 12rpx;
  margin-bottom: 8rpx;
}

.tag-grade {
  background-color: #e6fffb;
  color: #13c2c2;
}

.tag-difficulty {
  background-color: #f6f0ff;
  color: #722ed1;
}

.tag-yi-ci-duo-yi {
  background-color: #fff7e6;
  color: #fa8c16;
}

.tag-zhong-kao-gao-pin {
  background-color: #fff0f6;
  color: #eb2f96;
}

.tag-duo-yin-zi {
  background-color: #f6ffed;
  color: #52c41a;
}

/* 义项数量 */
.meanings-count {
  font-size: 24rpx;
  color: #999;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}

.empty-text {
  font-size: 32rpx;
  color: #999;
  margin-bottom: 20rpx;
}

.empty-hint {
  font-size: 26rpx;
  color: #ccc;
}
