<!--pages/word-list/word-list.wxml-->
<view class="container">
  <!-- Hero 头部区 -->
  <view class="hero-card">
  </view>

  <!-- 筛选区 -->
  <view class="filter-card">
    <!-- 搜索框 -->
    <view class="search-bar">
      <input
        class="search-input"
        placeholder="搜索实词、拼音或释义"
        value="{{searchKey}}"
        bindinput="onSearchInput"
      />
      <text class="search-icon">🔍</text>
    </view>

    <!-- 筛选按钮行 -->
    <view class="filter-bar">
      <!-- 年级筛选 -->
      <view class="filter-item">
        <text class="filter-label">年级：</text>
        <picker
          mode="selector"
          range="{{gradeOptions}}"
          value="{{gradeOptions.indexOf(selectedGrade)}}"
          bindchange="onGradeChange"
        >
          <view class="picker-button">
            {{selectedGrade}}
            <text class="arrow">▼</text>
          </view>
        </picker>
      </view>

      <!-- 难度筛选 -->
      <view class="filter-item">
        <text class="filter-label">难度：</text>
        <picker
          mode="selector"
          range="{{difficultyOptions}}"
          value="{{difficultyOptions.indexOf(selectedDifficulty)}}"
          bindchange="onDifficultyChange"
        >
          <view class="picker-button">
            {{selectedDifficulty}}
            <text class="arrow">▼</text>
          </view>
        </picker>
      </view>

      <!-- 重置按钮 -->
      <view class="reset-button" bindtap="onResetFilter">
        重置
      </view>
    </view>

    <!-- 筛选结果计数 -->
    <view class="filter-count">
      <text>已筛选出 {{filteredWords.length}} 个实词</text>
    </view>
  </view>

  <!-- 段落标题 -->
  <view class="section-label">词汇列表</view>

  <!-- 实词列表 -->
  <scroll-view class="word-list" scroll-y>
    <view class="word-list-inner">
    <view
      class="word-card card-{{item.colorLevel}}"
      wx:for="{{filteredWords}}"
      wx:key="id"
      data-id="{{item.id}}"
      bindtap="onWordTap"
    >
      <!-- 第一行：词 + 词性 + 徽章 -->
      <view class="word-header">
        <view class="word-title">
          <text class="word-text">{{item.word}}</text>
          <text class="category-tag" wx:if="{{item.category}}">{{item.category}}</text>
        </view>
        <view class="error-badge badge-{{item.colorLevel}}" wx:if="{{item.colorLevel !== 'white'}}">
          <text class="badge-text">{{item.colorLevel === 'red' ? '需加强' : '需巩固'}}</text>
        </view>
      </view>

      <!-- 第二行：标签区 -->
      <view class="tags-row">
        <text class="tag tag-match" wx:if="{{item.matchType}}">匹配：{{item.matchType}}</text>
        <text class="tag tag-grade" wx:if="{{item.grade}}">{{item.grade}}</text>
        <text class="tag tag-difficulty" wx:if="{{item.difficulty}}">{{item.difficulty}}</text>
        <text
          class="tag tag-{{tag.key}}"
          wx:for="{{item.displayTags}}"
          wx:for-item="tag"
          wx:key="key"
          wx:if="{{item.displayTags && item.displayTags.length > 0}}"
        >{{tag.label}}</text>
      </view>

      <!-- 义项数量 -->
      <view class="meanings-count">
        <text>{{item.meanings.length}}个义项</text>
      </view>
    </view>

    <!-- 空状态 -->
    <view class="empty-state" wx:if="{{filteredWords.length === 0}}">
      <view class="empty-icon-wrap">
        <text class="empty-icon-text">搜</text>
      </view>
      <text class="empty-text">没有找到相关实词</text>
      <text class="empty-hint">试试调整筛选条件</text>
    </view>
    </view>
  </scroll-view>
</view>
