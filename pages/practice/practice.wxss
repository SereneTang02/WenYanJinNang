/* pages/practice/practice.wxss - 温润古典·书卷风 */
.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #E8D5B8 0%, #F2E8D6 40%, #FBF6F0 100%);
  padding-bottom: 40rpx;
}

/* 进度条 */
.progress-bar {
  background-color: rgba(255, 255, 255, 0.75);
  padding: 25rpx 30rpx;
  box-shadow: 0 4rpx 16rpx rgba(166, 138, 100, 0.08);
  backdrop-filter: blur(10rpx);
}

.progress-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 15rpx;
}

.progress-text {
  font-size: 28rpx;
  font-weight: bold;
  color: #1A1008;
}

.score-text {
  font-size: 28rpx;
  font-weight: bold;
  color: #C4882E;
}

.progress-line {
  width: 100%;
  height: 10rpx;
  background-color: rgba(200, 175, 140, 0.2);
  border-radius: 5rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #C4882E, #E8C36A);
  transition: width 0.3s ease;
}

/* 题目区域 */
.question-section {
  margin: 30rpx 20rpx;
  background-color: rgba(255, 255, 255, 0.88);
  border: 1rpx solid rgba(200, 175, 140, 0.18);
  border-radius: 24rpx;
  padding: 40rpx 30rpx;
  box-shadow: 0 8rpx 32rpx rgba(166, 138, 100, 0.08);
  backdrop-filter: blur(10rpx);
}

.question-header {
  display: flex;
  align-items: baseline;
  margin-bottom: 30rpx;
  padding-bottom: 20rpx;
  border-bottom: 2rpx solid rgba(200, 175, 140, 0.18);
}

.word-title {
  font-size: 48rpx;
  font-weight: bold;
  color: #1A1008;
  margin-right: 15rpx;
}

.pinyin {
  font-size: 28rpx;
  color: #5C4D3E;
}

/* 例句 */
.sentence-box {
  background-color: rgba(200, 168, 124, 0.06);
  padding: 25rpx;
  border-radius: 20rpx;
  border-left: 8rpx solid #C4882E;
  margin-bottom: 30rpx;
}

.sentence-text {
  display: block;
  font-size: 32rpx;
  line-height: 1.8;
  color: #1A1008;
  margin-bottom: 15rpx;
}

.sentence-source {
  display: block;
  font-size: 24rpx;
  color: #5C4D3E;
  text-align: right;
}

/* 问题 */
.question-text {
  font-size: 30rpx;
  color: #4A3C30;
  margin-bottom: 25rpx;
  font-weight: 500;
}

/* 选项列表 */
.options-list {
  margin-bottom: 30rpx;
}

.option-item {
  display: flex;
  align-items: center;
  padding: 25rpx 20rpx;
  margin-bottom: 20rpx;
  background-color: rgba(200, 168, 124, 0.05);
  border-radius: 20rpx;
  border: 2rpx solid transparent;
  transition: all 0.3s;
  position: relative;
}

.option-item.selected {
  background-color: rgba(200, 168, 124, 0.1);
  border-color: #C4882E;
}

.option-item.correct {
  background-color: rgba(123, 175, 110, 0.08);
  border-color: #4CAF50;
}

.option-item.wrong {
  background-color: rgba(201, 107, 92, 0.08);
  border-color: #E05A47;
}

.option-label {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background-color: rgba(255, 255, 255, 0.8);
  border: 2rpx solid rgba(200, 175, 140, 0.3);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: bold;
  color: #4A3C30;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.option-item.selected .option-label {
  background: linear-gradient(135deg, #C4882E, #E8C36A);
  border-color: #C4882E;
  color: #fff;
}

.option-item.correct .option-label {
  background: linear-gradient(135deg, #4CAF50, #96C88A);
  border-color: #4CAF50;
  color: #fff;
}

.option-item.wrong .option-label {
  background: linear-gradient(135deg, #E05A47, #D98A7E);
  border-color: #E05A47;
  color: #fff;
}

.option-text {
  flex: 1;
  font-size: 30rpx;
  color: #1A1008;
  line-height: 1.6;
}

.option-icon {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #4CAF50, #96C88A);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: bold;
  margin-left: 15rpx;
}

.option-icon.wrong-icon {
  background: linear-gradient(135deg, #E05A47, #D98A7E);
}

/* 答题结果 */
.result-section {
  margin-top: 30rpx;
  padding-top: 30rpx;
  border-top: 2rpx dashed rgba(200, 175, 140, 0.3);
}

.result-header {
  display: flex;
  align-items: center;
  padding: 20rpx;
  border-radius: 16rpx;
  margin-bottom: 25rpx;
}

.result-header.correct {
  background-color: rgba(123, 175, 110, 0.08);
  border: 2rpx solid #4CAF50;
}

.result-header.wrong {
  background-color: rgba(201, 107, 92, 0.08);
  border: 2rpx solid #E05A47;
}

.result-icon {
  font-size: 40rpx;
  margin-right: 15rpx;
}

.result-text {
  font-size: 32rpx;
  font-weight: bold;
  color: #1A1008;
}

/* 解析 */
.explanation {
  padding: 20rpx;
  background-color: rgba(200, 168, 124, 0.06);
  border-radius: 16rpx;
  margin-bottom: 25rpx;
  border: 1rpx solid rgba(200, 175, 140, 0.12);
}

.explanation-title {
  font-size: 26rpx;
  color: #4A3C30;
  margin-bottom: 10rpx;
  font-weight: bold;
}

.explanation-content {
  margin-bottom: 15rpx;
}

.correct-meaning {
  font-size: 30rpx;
  color: #1A1008;
  font-weight: 500;
}

.usage-note {
  padding: 15rpx;
  background-color: rgba(255, 255, 255, 0.6);
  border-radius: 12rpx;
  margin-top: 15rpx;
}

.note-label {
  font-size: 24rpx;
  color: #5C4D3E;
  margin-right: 8rpx;
}

.note-text {
  font-size: 26rpx;
  color: #4A3C30;
  line-height: 1.6;
}

/* 操作按钮 */
.action-buttons {
  display: flex;
  gap: 20rpx;
}

.btn {
  flex: 1;
  height: 84rpx;
  line-height: 84rpx;
  border-radius: 42rpx;
  font-size: 28rpx;
  font-weight: bold;
  border: none;
}

.btn-outline {
  background-color: rgba(255, 255, 255, 0.88);
  color: #9E6B2C;
  border: 2rpx solid #C9B18A;
}

.btn-primary {
  background: linear-gradient(135deg, #C4882E, #9E6B2C);
  color: #fff;
}

.submit-section {
  margin-top: 20rpx;
}

.btn-submit {
  width: 100%;
  height: 92rpx;
  line-height: 92rpx;
  background: linear-gradient(135deg, #C4882E, #9E6B2C);
  color: #fff;
  border-radius: 46rpx;
  font-size: 32rpx;
  font-weight: bold;
  border: none;
  box-shadow: 0 6rpx 20rpx rgba(166, 138, 100, 0.25);
}

/* 完成页面 */
.finish-section {
  margin: 100rpx 40rpx;
  text-align: center;
}

.finish-icon {
  font-size: 120rpx;
  margin-bottom: 30rpx;
}

.finish-title {
  font-size: 48rpx;
  font-weight: bold;
  color: #1A1008;
  margin-bottom: 50rpx;
}

.score-card {
  background-color: rgba(255, 255, 255, 0.75);
  border: 1rpx solid rgba(200, 175, 140, 0.18);
  border-radius: 28rpx;
  padding: 50rpx;
  margin-bottom: 40rpx;
  box-shadow: 0 8rpx 32rpx rgba(166, 138, 100, 0.08);
  backdrop-filter: blur(10rpx);
}

.score-big {
  font-size: 120rpx;
  font-weight: bold;
  color: #C4882E;
  line-height: 1.2;
}

.score-label {
  font-size: 32rpx;
  color: #5C4D3E;
  margin-top: 10rpx;
}

.stats-row {
  display: flex;
  align-items: center;
  justify-content: space-around;
  background-color: rgba(255, 255, 255, 0.75);
  border: 1rpx solid rgba(200, 175, 140, 0.18);
  border-radius: 24rpx;
  padding: 40rpx 20rpx;
  margin-bottom: 50rpx;
  backdrop-filter: blur(10rpx);
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-value {
  font-size: 48rpx;
  font-weight: bold;
  color: #1A1008;
  margin-bottom: 10rpx;
}

.stat-label {
  font-size: 26rpx;
  color: #5C4D3E;
}

.stat-divider {
  width: 2rpx;
  height: 60rpx;
  background-color: rgba(200, 175, 140, 0.25);
}

.finish-buttons {
  padding: 0 20rpx;
}

.btn-block {
  width: 100%;
  height: 92rpx;
  line-height: 92rpx;
  font-size: 32rpx;
}
