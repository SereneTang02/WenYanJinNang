/* pages/practice-config/practice-config.wxss - 温润古典·书卷风 */
page {
  background: linear-gradient(180deg, #E8D5B8, #FBF6F0);
}

/* 加载中占位 */
.page-loading {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(180deg, #E8D5B8, #FBF6F0);
  z-index: 9999;
}

.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #E8D5B8, #FBF6F0);
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
  width: 100%;
}

/* 头部 */
.header {
  padding: 30rpx 30rpx 20rpx;
  text-align: center;
  width: 100%;
  box-sizing: border-box;
}

.title {
  font-size: 48rpx;
  font-weight: bold;
  color: #1A1008;
  display: block;
  margin-bottom: 10rpx;
}

.subtitle {
  font-size: 26rpx;
  color: #4A3C30;
  display: block;
}

/* 滚动区域 */
.config-scroll {
  flex: 1;
  width: 100%;
  box-sizing: border-box;
}

/* 滚动内容包装器 */
.config-scroll > view {
  padding: 20rpx 30rpx;
  min-height: 100%;
  display: flex;
  flex-direction: column;
}

/* 配置区块 */
.config-section {
  background: rgba(255, 255, 255, 0.88);
  border: 1rpx solid rgba(200, 175, 140, 0.18);
  border-radius: 28rpx;
  padding: 30rpx 25rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(166, 138, 100, 0.08);
  box-sizing: border-box;
}

.config-section:last-child {
  margin-bottom: 0;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 20rpx;
}

.section-icon {
  font-size: 36rpx;
  margin-right: 15rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #1A1008;
}

.section-desc {
  font-size: 24rpx;
  color: #5C4D3E;
  margin-left: 15rpx;
}

/* 题型卡片 */
.type-cards {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  margin: -10rpx -10rpx 0 -10rpx;
}

.type-card {
  position: relative;
  flex: 1;
  min-width: 200rpx;
  background: #F5F0E8;
  border: 2rpx solid rgba(200, 175, 140, 0.25);
  border-radius: 20rpx;
  padding: 25rpx 20rpx;
  text-align: center;
  transition: all 0.3s;
  margin: 10rpx;
  box-sizing: border-box;
}

.type-card.active {
  background: rgba(200, 168, 124, 0.08);
  border-color: #C4882E;
  box-shadow: 0 4rpx 16rpx rgba(200, 168, 124, 0.15);
}

.type-icon {
  font-size: 40rpx;
  margin-bottom: 10rpx;
}

.type-label {
  font-size: 28rpx;
  font-weight: bold;
  color: #1A1008;
  display: block;
  margin-bottom: 8rpx;
}

.type-desc {
  font-size: 22rpx;
  color: #5C4D3E;
  display: block;
}

.type-check {
  position: absolute;
  top: 10rpx;
  right: 10rpx;
  width: 36rpx;
  height: 36rpx;
  background: #C4882E;
  color: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
}

/* 数量控制 */
.count-control {
  display: flex;
  align-items: center;
  justify-content: center;
}

.count-btn {
  width: 70rpx;
  height: 70rpx;
  background: #F0E8D8;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  color: #4A3C30;
  font-weight: bold;
  transition: all 0.2s;
  margin: 0 15rpx;
}

.count-btn:active {
  background: #E5D9C5;
  transform: scale(0.95);
}

.count-input {
  width: 150rpx;
  height: 70rpx;
  text-align: center;
  font-size: 36rpx;
  font-weight: bold;
  color: #1A1008;
  background: #F5F0E8;
  border-radius: 35rpx;
  border: 2rpx solid rgba(200, 175, 140, 0.25);
}

/* 选词方式标签 */
.mode-tabs {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  margin: -7.5rpx -7.5rpx 10rpx -7.5rpx;
}

.mode-tab {
  flex: 1;
  min-width: 150rpx;
  background: #F5F0E8;
  border: 2rpx solid rgba(200, 175, 140, 0.25);
  border-radius: 16rpx;
  padding: 20rpx 15rpx;
  text-align: center;
  transition: all 0.3s;
  margin: 7.5rpx;
  box-sizing: border-box;
}

.mode-tab.active {
  background: rgba(200, 168, 124, 0.08);
  border-color: #C4882E;
}

.mode-icon {
  font-size: 28rpx;
  margin-right: 8rpx;
}

.mode-label {
  font-size: 26rpx;
  color: #1A1008;
}

/* 选词内容区 */
.mode-content {
  background: #F5F0E8;
  border-radius: 20rpx;
  padding: 25rpx;
}

/* 分类选择器 */
.category-selectors {
  display: flex;
  flex-direction: column;
}

.selector-item {
  display: flex;
  flex-direction: column;
  margin-bottom: 20rpx;
}

.selector-item:last-child {
  margin-bottom: 0;
}

.selector-label {
  font-size: 26rpx;
  color: #4A3C30;
  margin-bottom: 12rpx;
}

.picker-display {
  background: rgba(255, 255, 255, 0.88);
  border: 2rpx solid rgba(200, 175, 140, 0.25);
  border-radius: 16rpx;
  padding: 20rpx 25rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  font-size: 28rpx;
  color: #1A1008;
}

.arrow {
  font-size: 24rpx;
  color: #5C4D3E;
}

.word-count-tip {
  text-align: center;
  font-size: 26rpx;
  color: #4A3C30;
  padding: 15rpx;
  background: rgba(255, 255, 255, 0.88);
  border-radius: 16rpx;
}

.highlight {
  color: #C4882E;
  font-weight: bold;
  font-size: 32rpx;
}

/* 随机选择 */
.random-selector {
  display: flex;
  flex-direction: column;
}

.random-label {
  font-size: 26rpx;
  color: #4A3C30;
  text-align: center;
  margin-bottom: 20rpx;
}

.random-tip {
  text-align: center;
  font-size: 24rpx;
  color: #5C4D3E;
  margin-top: 20rpx;
}

/* 错题本选择 */
.error-selector {
  display: flex;
  flex-direction: column;
}

.error-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-bottom: 15rpx;
  border-bottom: 2rpx solid rgba(200, 175, 140, 0.15);
  margin-bottom: 20rpx;
}

.error-count {
  font-size: 26rpx;
  color: #4A3C30;
}

.select-all-btn {
  display: flex;
  align-items: center;
  font-size: 26rpx;
  color: #4A3C30;
}

.select-all-btn .checkbox {
  margin-right: 10rpx;
}

.checkbox {
  font-size: 32rpx;
  color: #5C4D3E;
}

.checkbox.checked {
  color: #C4882E;
}

.word-list {
  display: flex;
  flex-direction: column;
  max-height: 500rpx;
  overflow-y: auto;
}

.word-item {
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.88);
  border-radius: 16rpx;
  padding: 20rpx;
  border: 2rpx solid transparent;
  transition: all 0.2s;
  margin-bottom: 15rpx;
}

.word-item:last-child {
  margin-bottom: 0;
}

.word-item.selected {
  background: rgba(200, 168, 124, 0.08);
  border-color: #C4882E;
}

.word-item .checkbox {
  margin-right: 15rpx;
}

.word-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.word-info .word-text {
  margin-bottom: 8rpx;
}

.word-text {
  font-size: 30rpx;
  font-weight: bold;
  color: #1A1008;
}

.word-meaning {
  font-size: 24rpx;
  color: #5C4D3E;
}

.empty-tip {
  text-align: center;
  padding: 60rpx 0;
  font-size: 26rpx;
  color: #5C4D3E;
}

/* 手动选择 */
.manual-selector {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.manual-tip {
  font-size: 26rpx;
  color: #4A3C30;
  text-align: center;
  margin-bottom: 20rpx;
}

.select-btn {
  width: 200rpx;
  height: 70rpx;
  line-height: 70rpx;
  background: linear-gradient(135deg, #C4882E, #A56A1F);
  color: #FFFDF8;
  border-radius: 35rpx;
  font-size: 28rpx;
  border: none;
  text-align: center;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
  box-sizing: border-box;
}

/* 底部按钮 */
.footer {
  padding: 20rpx 30rpx 30rpx;
  width: 100%;
  box-sizing: border-box;
}

.btn-start {
  width: 100%;
  height: 92rpx;
  line-height: 92rpx;
  background: linear-gradient(135deg, #C4882E, #A56A1F);
  color: #FFFDF8;
  border-radius: 46rpx;
  font-size: 32rpx;
  font-weight: bold;
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(200, 168, 124, 0.3);
  text-align: center;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
}

.btn-start.disabled {
  background: linear-gradient(135deg, #C9B18A, #C8B89C);
  color: rgba(255, 253, 248, 0.5);
  box-shadow: none;
}

/* 弹窗 */
.word-selector-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
  display: flex;
  align-items: flex-end;
}

.modal-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(74, 55, 40, 0.4);
}

.modal-content {
  position: relative;
  width: 100%;
  height: 85vh;
  background: #FFFFFF;
  border-radius: 28rpx 28rpx 0 0;
  display: flex;
  flex-direction: column;
}

.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx;
  border-bottom: 2rpx solid rgba(200, 175, 140, 0.15);
}

.modal-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #1A1008;
}

.modal-close {
  width: 50rpx;
  height: 50rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  color: #5C4D3E;
}

.search-bar {
  position: relative;
  margin: 25rpx 30rpx;
}

.search-input {
  width: 100%;
  height: 72rpx;
  background: #F5F0E8;
  border-radius: 36rpx;
  padding: 0 50rpx 0 30rpx;
  font-size: 28rpx;
  color: #1A1008;
}

.search-icon {
  position: absolute;
  right: 25rpx;
  top: 50%;
  transform: translateY(-50%);
  font-size: 28rpx;
  color: #5C4D3E;
}

.select-all-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 30rpx 20rpx;
}

.selected-count {
  font-size: 26rpx;
  color: #5C4D3E;
}

.word-list-scroll {
  flex: 1;
  height: 0;
  padding: 0 30rpx;
}

.modal-footer {
  padding: 25rpx 30rpx;
  border-top: 2rpx solid rgba(200, 175, 140, 0.15);
}

.btn-confirm {
  width: 100%;
  height: 92rpx;
  line-height: 92rpx;
  background: linear-gradient(135deg, #C4882E, #A56A1F);
  color: #FFFDF8;
  border-radius: 46rpx;
  font-size: 30rpx;
  font-weight: bold;
  border: none;
  text-align: center;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
  box-shadow: 0 6rpx 20rpx rgba(200, 168, 124, 0.3);
}
