<!--pages/teacher-info/teacher-info.wxml-->
<view class="container">
  <!-- 顶部栏 -->
  <view class="hero-card">
    <view class="hero-icon-wrap">
      <text class="hero-icon-text">师</text>
    </view>
    <view class="hero-title">完善教师信息</view>
    <view class="hero-sub">填写信息，开启教学之旅</view>
  </view>

  <!-- 表单区域 -->
  <view class="form-card">
    <!-- 学校名称（必填） -->
    <view class="form-item">
      <view class="form-label">
        <text class="label-text">学校</text>
        <text class="required-star">*</text>
      </view>
      <input class="form-input" placeholder="请输入学校名称" value="{{school}}" bindinput="onSchoolInput" maxlength="30" />
    </view>

    <!-- 真实姓名（必填） -->
    <view class="form-item">
      <view class="form-label">
        <text class="label-text">姓名</text>
        <text class="required-star">*</text>
      </view>
      <input class="form-input" placeholder="请输入真实姓名" value="{{realName}}" bindinput="onRealNameInput" maxlength="20" />
    </view>

    <!-- 科目选择 -->
    <view class="form-item">
      <view class="form-label">
        <text class="label-text">科目</text>
        <text class="required-star">*</text>
      </view>
      <picker class="picker" mode="selector" range="{{subjectOptions}}" value="{{subjectIndex}}" bindchange="onSubjectChange">
        <view class="picker-content">
          <text class="picker-value">{{subject}}</text>
          <text class="picker-arrow">▼</text>
        </view>
      </picker>
    </view>

    <!-- 手机号 -->
    <view class="form-item">
      <view class="form-label">
        <text class="label-text">手机号</text>
        <text class="optional-tag">选填</text>
      </view>
      <input class="form-input" placeholder="请输入手机号" type="number" value="{{phone}}" bindinput="onPhoneInput" maxlength="11" />
    </view>

    <!-- 教师资格证 -->
    <view class="form-item last">
      <view class="form-label">
        <text class="label-text">教师资格证</text>
        <text class="optional-tag">选填</text>
      </view>
      <view class="upload-area">
        <view class="uploaded-image" wx:for="{{certificationImages}}" wx:key="*this">
          <image class="cert-image" src="{{item}}" mode="aspectFill" data-index="{{index}}" bindtap="onPreviewImage" />
          <view class="delete-btn" data-index="{{index}}" bindtap="onDeleteImage">x</view>
        </view>
        <view class="upload-btn" wx:if="{{certificationImages.length < 2}}" bindtap="onUploadCertification">
          <text class="upload-plus">+</text>
          <text class="upload-text">上传证件</text>
        </view>
      </view>
      <view class="upload-hint">最多上传 2 张图片</view>
    </view>
  </view>

  <!-- 提示 -->
  <view class="tip-card">
    <view class="tip-icon-wrap">
      <text class="tip-icon-text">i</text>
    </view>
    <text class="tip-text">提交后将自动通过认证，可立即使用教师端功能</text>
  </view>

  <!-- 提交按钮 -->
  <view class="submit-area">
    <button class="submit-btn {{loading ? 'disabled' : ''}}" bindtap="onSubmit" disabled="{{loading}}">
      {{loading ? '提交中...' : '提交认证'}}
    </button>
  </view>
</view>
