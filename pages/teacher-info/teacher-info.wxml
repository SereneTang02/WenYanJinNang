<!--pages/teacher-info/teacher-info.wxml-->
<view class="container">
  <!-- 顶部标题 -->
  <view class="header">
    <view class="header-icon">👨‍🏫</view>
    <view class="title">完善教师信息</view>
    <view class="subtitle">填写信息，开启教学之旅</view>
  </view>

  <!-- 表单区域 -->
  <view class="form-container">
    <!-- 学校名称（必填） -->
    <view class="form-item required">
      <view class="form-label">
        <text class="label-text">学校</text>
        <text class="required-star">*</text>
      </view>
      <input
        class="input"
        placeholder="请输入学校名称"
        value="{{school}}"
        bindinput="onSchoolInput"
        maxlength="30"
      />
    </view>

    <!-- 真实姓名（必填） -->
    <view class="form-item required">
      <view class="form-label">
        <text class="label-text">姓名</text>
        <text class="required-star">*</text>
      </view>
      <input
        class="input"
        placeholder="请输入真实姓名"
        value="{{realName}}"
        bindinput="onRealNameInput"
        maxlength="20"
      />
    </view>

    <!-- 科目选择（必填） -->
    <view class="form-item required">
      <view class="form-label">
        <text class="label-text">科目</text>
        <text class="required-star">*</text>
      </view>
      <picker
        class="picker"
        mode="selector"
        range="{{subjectOptions}}"
        value="{{subjectIndex}}"
        bindchange="onSubjectChange"
      >
        <view class="picker-content">
          <text class="picker-value">{{subject}}</text>
          <text class="picker-arrow">▼</text>
        </view>
      </picker>
    </view>

    <!-- 手机号（可选） -->
    <view class="form-item">
      <view class="form-label">
        <text class="label-text">手机号</text>
        <text class="optional-tag">选填</text>
      </view>
      <input
        class="input"
        placeholder="请输入手机号"
        type="number"
        value="{{phone}}"
        bindinput="onPhoneInput"
        maxlength="11"
      />
    </view>

    <!-- 教师资格证（可选） -->
    <view class="form-item">
      <view class="form-label">
        <text class="label-text">教师资格证</text>
        <text class="optional-tag">选填</text>
      </view>
      <view class="upload-section">
        <!-- 已上传的图片 -->
        <view
          class="uploaded-image"
          wx:for="{{certificationImages}}"
          wx:key="*this"
        >
          <image
            class="cert-image"
            src="{{item}}"
            mode="aspectFill"
            data-index="{{index}}"
            bindtap="onPreviewImage"
          />
          <view class="delete-btn" data-index="{{index}}" bindtap="onDeleteImage">
            ×
          </view>
        </view>

        <!-- 上传按钮 -->
        <view
          class="upload-btn"
          wx:if="{{certificationImages.length < 2}}"
          bindtap="onUploadCertification"
        >
          <text class="upload-icon">📷</text>
          <text class="upload-text">上传证件</text>
        </view>
      </view>
      <view class="upload-hint">最多上传2张图片</view>
    </view>
  </view>

  <!-- 提示信息 -->
  <view class="tips">
    <view class="tips-icon">💡</view>
    <view class="tips-text">
      <text>提交后将自动通过认证，您可以立即开始使用教师端功能</text>
    </view>
  </view>

  <!-- 提交按钮 -->
  <view class="submit-section">
    <button
      class="submit-button {{loading ? 'loading' : ''}}"
      bindtap="onSubmit"
      disabled="{{loading}}"
    >
      {{loading ? '提交中...' : '提交认证'}}
    </button>
  </view>
</view>
