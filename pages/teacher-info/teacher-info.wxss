/* pages/teacher-info/teacher-info.wxss - 温润古典·书卷风 */
page {
  background: #FBF6F0;
}

.container {
  padding: 0 0 60rpx;
  min-height: 100vh;
}

/* ===== 顶部英雄卡片 ===== */
.hero-card {
  background: linear-gradient(180deg, #E8D5B8 0%, #F2E8D6 60%, #FBF6F0 100%);
  padding: 50rpx 36rpx 44rpx;
  color: #1A1008;
  border-radius: 0 0 48rpx 48rpx;
  margin-bottom: 36rpx;
  text-align: center;
  position: relative;
  overflow: hidden;
}

.hero-card::after {
  content: '';
  position: absolute;
  top: -50rpx;
  right: -50rpx;
  width: 220rpx;
  height: 220rpx;
  border-radius: 50%;
  background: rgba(200, 168, 124, 0.1);
}

.hero-icon-wrap {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  background: rgba(200, 168, 124, 0.08);
  border: 2rpx solid #C4882E;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 16rpx;
}

.hero-icon-text {
  font-size: 40rpx;
  font-weight: bold;
  color: #C4882E;
}

.hero-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #1A1008;
  margin-bottom: 8rpx;
}

.hero-sub {
  font-size: 26rpx;
  color: #4A3C30;
}

/* ===== 表单卡片 ===== */
.form-card {
  background: rgba(255, 255, 255, 0.88);
  border: 1rpx solid rgba(200, 175, 140, 0.18);
  border-radius: 24rpx;
  padding: 36rpx 30rpx;
  margin: 0 24rpx 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(166, 138, 100, 0.08);
}

.form-item {
  margin-bottom: 32rpx;
  padding-bottom: 32rpx;
  border-bottom: 1rpx solid rgba(200, 175, 140, 0.15);
}

.form-item.last {
  margin-bottom: 0;
  padding-bottom: 0;
  border-bottom: none;
}

.form-label {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.label-text {
  font-size: 30rpx;
  font-weight: 500;
  color: #1A1008;
}

.required-star {
  color: #E05A47;
  margin-left: 6rpx;
  font-size: 32rpx;
}

.optional-tag {
  font-size: 22rpx;
  color: #5C4D3E;
  background: #F5F0E8;
  padding: 4rpx 14rpx;
  border-radius: 10rpx;
  margin-left: 12rpx;
}

/* 选择器 */
.picker-content {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 88rpx;
  padding: 0 24rpx;
  background: #F5F0E8;
  border-radius: 20rpx;
  border: 2rpx solid transparent;
}

.picker-content:active {
  border-color: #C4882E;
  background: rgba(200, 168, 124, 0.06);
}

.picker-value {
  font-size: 28rpx;
  color: #1A1008;
}

.picker-arrow {
  font-size: 20rpx;
  color: #5C4D3E;
}

/* 输入框 */
.form-input {
  height: 88rpx;
  padding: 0 24rpx;
  background: #F5F0E8;
  border-radius: 20rpx;
  font-size: 28rpx;
  color: #1A1008;
  border: 2rpx solid transparent;
}

.form-input:focus {
  border-color: #C4882E;
  background: rgba(200, 168, 124, 0.06);
}

/* ===== 上传区域 ===== */
.upload-area {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.uploaded-image {
  width: 180rpx;
  height: 180rpx;
  position: relative;
  border-radius: 20rpx;
  overflow: hidden;
}

.cert-image {
  width: 100%;
  height: 100%;
}

.delete-btn {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 44rpx;
  height: 44rpx;
  background: rgba(74, 55, 40, 0.45);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 28rpx;
  line-height: 1;
}

.upload-btn {
  width: 180rpx;
  height: 180rpx;
  background: #F5F0E8;
  border: 2rpx dashed #C9B18A;
  border-radius: 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.upload-btn:active {
  background: rgba(200, 168, 124, 0.06);
  border-color: #C4882E;
}

.upload-plus {
  font-size: 48rpx;
  color: #5C4D3E;
  line-height: 1;
  margin-bottom: 8rpx;
}

.upload-text {
  font-size: 22rpx;
  color: #5C4D3E;
}

.upload-hint {
  font-size: 22rpx;
  color: #5C4D3E;
  margin-top: 14rpx;
}

/* ===== 提示 ===== */
.tip-card {
  display: flex;
  align-items: center;
  margin: 0 24rpx 36rpx;
  padding: 22rpx 24rpx;
  background: rgba(200, 168, 124, 0.1);
  border-radius: 20rpx;
}

.tip-icon-wrap {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  background: rgba(200, 168, 124, 0.15);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 12rpx;
  flex-shrink: 0;
}

.tip-icon-text {
  font-size: 22rpx;
  font-weight: bold;
  color: #C4882E;
}

.tip-text {
  font-size: 24rpx;
  color: #9E6B2C;
  line-height: 1.5;
}

/* ===== 提交按钮 ===== */
.submit-area {
  padding: 0 24rpx;
}

.submit-btn {
  width: 100%;
  height: 92rpx;
  line-height: 92rpx;
  background: linear-gradient(135deg, #C4882E, #A56A1F);
  color: #FFFDF8;
  border-radius: 46rpx;
  font-size: 34rpx;
  font-weight: bold;
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(200, 168, 124, 0.3);
}

.submit-btn::after {
  border: none;
}

.submit-btn:active:not(.disabled) {
  opacity: 0.85;
}

.submit-btn.disabled {
  opacity: 0.6;
}
