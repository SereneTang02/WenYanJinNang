/* pages/category-detail/category-detail.wxss - 温润古典·书卷风 */
.container {
  padding: 20rpx;
  background: #FBF6F0;
  min-height: 100vh;
}

.card {
  background: rgba(255, 255, 255, 0.88);
  border: 1rpx solid rgba(200, 175, 140, 0.18);
  border-radius: 24rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(166, 138, 100, 0.08);
}

.header-card {
  margin-bottom: 30rpx;
  position: relative;
}

.back-button {
  font-size: 40rpx;
  color: #4A3C30;
  margin-bottom: 10rpx;
  cursor: pointer;
}

.header-title {
  font-size: 48rpx;
  font-weight: bold;
  color: #1A1008;
  margin-bottom: 10rpx;
}

.header-subtitle {
  font-size: 28rpx;
  color: #5C4D3E;
}

.secondary-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.secondary-card {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  transition: all 0.3s;
}

.secondary-card:active {
  transform: scale(0.98);
  background: rgba(232, 213, 184, 0.2);
}

.secondary-info {
  flex: 1;
}

.secondary-name {
  font-size: 36rpx;
  font-weight: bold;
  color: #1A1008;
  margin-bottom: 8rpx;
}

.secondary-desc {
  font-size: 26rpx;
  color: #5C4D3E;
  margin-bottom: 8rpx;
}

.secondary-count {
  font-size: 24rpx;
  color: #4A3C30;
}

.secondary-arrow {
  font-size: 60rpx;
  color: #C9B18A;
}

.empty-state {
  text-align: center;
  padding: 100rpx 0;
  color: #5C4D3E;
  font-size: 28rpx;
}
