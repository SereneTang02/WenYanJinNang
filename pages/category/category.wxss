/* pages/category/category.wxss */
page {
  background: #f0f2f5;
}

.container {
  padding: 0 0 40rpx;
}

/* ===== 顶部栏 ===== */
.hero-card {
  background: linear-gradient(160deg, #4A90E2 0%, #357ABD 50%, #2E6BA6 100%);
  padding: 50rpx 36rpx 40rpx;
  color: #fff;
  border-radius: 0 0 48rpx 48rpx;
  margin-bottom: 36rpx;
  text-align: center;
  position: relative;
  overflow: hidden;
}

.hero-card::after {
  content: '';
  position: absolute;
  top: -60rpx;
  right: -60rpx;
  width: 240rpx;
  height: 240rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.06);
}

.hero-title {
  font-size: 40rpx;
  font-weight: bold;
  margin-bottom: 8rpx;
}

.hero-sub {
  font-size: 26rpx;
  opacity: 0.75;
}

/* ===== 区域标题 ===== */
.section-label {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  padding: 0 36rpx;
  margin-bottom: 20rpx;
}

/* ===== 年级卡片 ===== */
.grade-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin: 0 24rpx 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
  display: flex;
  align-items: center;
}

.grade-card:active {
  transform: scale(0.98);
  opacity: 0.9;
}

.grade-icon-wrap {
  width: 72rpx;
  height: 72rpx;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.grade-icon-text {
  font-size: 26rpx;
  font-weight: bold;
  color: #fff;
}

.grade-info {
  flex: 1;
}

.grade-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 6rpx;
}

.grade-count {
  font-size: 24rpx;
  color: #999;
}

.grade-arrow {
  font-size: 40rpx;
  color: #d0d0d0;
}
