/* pages/category/category.wxss */
.header-card {
  text-align: center;
  background: linear-gradient(135deg, #4A90E2 0%, #357ABD 100%);
  color: white;
  padding: 40rpx 30rpx;
}

.header-title {
  font-size: 42rpx;
  font-weight: bold;
  margin-bottom: 12rpx;
}

.header-subtitle {
  font-size: 26rpx;
  opacity: 0.9;
}

.category-list {
  margin-top: 20rpx;
}

.category-card {
  display: flex;
  align-items: center;
  gap: 24rpx;
  margin-bottom: 20rpx;
  padding: 30rpx;
  transition: all 0.3s;
}

.category-card:active {
  transform: scale(0.98);
  background-color: #f5f5f5;
}

.category-icon {
  font-size: 64rpx;
  width: 80rpx;
  text-align: center;
}

.category-info {
  flex: 1;
}

.category-name {
  font-size: 34rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}

.category-desc {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 8rpx;
}

.category-count {
  font-size: 24rpx;
  color: #4A90E2;
}

.category-arrow {
  font-size: 48rpx;
  color: #ccc;
}
