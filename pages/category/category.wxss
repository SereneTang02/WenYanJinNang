/* pages/category/category.wxss - 温润古典·书卷风 */
page {
  background: #FBF6F0;
}

.container {
  padding: 0 0 40rpx;
}

/* ===== 顶部栏 ===== */
.hero-card {
  background: linear-gradient(180deg, #E8D5B8 0%, #F2E8D6 60%, #FBF6F0 100%);
  padding: 50rpx 36rpx 40rpx;
  color: #1A1008;
  border-radius: 0 0 48rpx 48rpx;
  margin-bottom: 36rpx;
  text-align: center;
  position: relative;
  overflow: hidden;
}

.hero-card::after {
  content: '';
  position: absolute;
  top: -60rpx;
  right: -60rpx;
  width: 240rpx;
  height: 240rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(200, 168, 124, 0.15) 0%, transparent 70%);
}

.hero-title {
  font-size: 40rpx;
  font-weight: bold;
  margin-bottom: 8rpx;
  letter-spacing: 4rpx;
  color: #1A1008;
}

.hero-sub {
  font-size: 26rpx;
  color: #4A3C30;
}

/* ===== 区域标题 ===== */
.section-label {
  font-size: 32rpx;
  font-weight: bold;
  color: #1A1008;
  padding: 0 36rpx;
  margin-bottom: 20rpx;
  letter-spacing: 4rpx;
}

/* ===== 年级卡片 ===== */
.grade-card {
  background: rgba(255, 255, 255, 0.88);
  border: 1rpx solid rgba(200, 175, 140, 0.18);
  border-radius: 24rpx;
  padding: 30rpx;
  margin: 0 24rpx 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(166, 138, 100, 0.08);
  display: flex;
  align-items: center;
  transition: all 0.3s;
}

.grade-card:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 10rpx rgba(166, 138, 100, 0.12);
}

.grade-icon-wrap {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
  flex-shrink: 0;
  background: rgba(200, 168, 124, 0.08);
  border: 2rpx solid #C4882E;
}

.grade-icon-text {
  font-size: 26rpx;
  font-weight: bold;
  color: #C4882E;
}

.grade-info {
  flex: 1;
}

.grade-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #1A1008;
  margin-bottom: 6rpx;
}

.grade-count {
  font-size: 24rpx;
  color: #5C4D3E;
}

.grade-arrow {
  font-size: 40rpx;
  color: #C9B18A;
}
