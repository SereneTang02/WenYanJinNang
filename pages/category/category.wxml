<!--pages/category/category.wxml-->
<view class="container">
  <!-- 顶部栏 -->
  <view class="hero-card">
    <view class="hero-title">分类学习</view>
    <view class="hero-sub">按年级选择实词进行背诵</view>
  </view>

  <!-- 年级列表 -->
  <view class="section-label">选择年级</view>

  <view class="grade-card" wx:for="{{categories}}" wx:key="grade" bindtap="selectCategory" data-grade="{{item.grade}}">
    <view class="grade-icon-wrap">
      <text class="grade-icon-text">{{item.grade}}</text>
    </view>
    <view class="grade-info">
      <view class="grade-name">{{item.name}}</view>
      <view class="grade-count">共 {{item.count}} 个实词</view>
    </view>
    <view class="grade-arrow">›</view>
  </view>
</view>
