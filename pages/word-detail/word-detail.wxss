/* pages/word-detail/word-detail.wxss */
page {
  background: #f0f2f5;
}

.container {
  min-height: 100vh;
  padding-bottom: 150rpx;
}

/* 顶部蓝色区域 */
.hero-header {
  background: linear-gradient(160deg, #4A90E2 0%, #357ABD 50%, #2E6BA6 100%);
  padding: 60rpx 36rpx 48rpx;
  color: #fff;
  border-radius: 0 0 48rpx 48rpx;
  position: relative;
  overflow: hidden;
}

.hero-header::after {
  content: '';
  position: absolute;
  top: -60rpx;
  right: -60rpx;
  width: 240rpx;
  height: 240rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.06);
}

.word-title {
  font-size: 64rpx;
  font-weight: bold;
  margin-bottom: 12rpx;
}

.pinyin {
  font-size: 28rpx;
  opacity: 0.75;
  margin-bottom: 24rpx;
}

/* 标签区 */
.tags-section {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
}

.tag {
  padding: 10rpx 20rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  margin-right: 12rpx;
  margin-bottom: 8rpx;
  background: rgba(255, 255, 255, 0.2);
  color: #fff;
  line-height: 1;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 学习进度卡片 */
.progress-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx;
  margin: -24rpx 24rpx 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
  position: relative;
  z-index: 1;
}

.progress-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.progress-stats {
  display: flex;
  justify-content: space-around;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-num {
  font-size: 40rpx;
  font-weight: bold;
  margin-bottom: 6rpx;
}

.stat-num.correct {
  color: #52c41a;
}

.stat-num.wrong {
  color: #ff4d4f;
}

.stat-num.rate {
  color: #4A90E2;
}

.stat-label {
  font-size: 24rpx;
  color: #999;
}

/* 义项列表 */
.meanings-section {
  padding: 0 24rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.meaning-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

/* 义项标题 */
.meaning-header {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.meaning-number {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: #4A90E2;
  color: #fff;
  font-size: 24rpx;
  font-weight: bold;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 12rpx;
  flex-shrink: 0;
}

.meaning-gloss {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  flex: 1;
}

.core-badge {
  padding: 4rpx 12rpx;
  background-color: #ff4d4f;
  color: #fff;
  font-size: 22rpx;
  border-radius: 8rpx;
  font-weight: bold;
  flex-shrink: 0;
}

/* 用法说明 */
.usage-note {
  display: flex;
  align-items: flex-start;
  padding: 16rpx;
  background-color: #e6f7ff;
  border-radius: 12rpx;
  margin-bottom: 16rpx;
}

.note-icon {
  font-size: 28rpx;
  margin-right: 8rpx;
  flex-shrink: 0;
}

.note-text {
  font-size: 26rpx;
  color: #333;
  flex: 1;
  line-height: 1.6;
}

/* 例句列表 */
.examples-list {
  margin-top: 12rpx;
}

.example-card {
  padding: 16rpx;
  background-color: #fafafa;
  margin-bottom: 12rpx;
  border-radius: 12rpx;
}

.example-card:last-child {
  margin-bottom: 0;
}

.example-text {
  display: block;
  font-size: 28rpx;
  color: #333;
  line-height: 1.8;
  margin-bottom: 10rpx;
}

.example-meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.example-source {
  font-size: 24rpx;
  color: #4A90E2;
  padding: 4rpx 12rpx;
  background-color: #e6f7ff;
  border-radius: 8rpx;
}

.example-grade {
  font-size: 22rpx;
  color: #fff;
  padding: 4rpx 12rpx;
  background-color: #13c2c2;
  border-radius: 8rpx;
}

/* 底部操作按钮 */
.action-buttons {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  padding: 20rpx 24rpx;
  background-color: #fff;
  box-shadow: 0 -2rpx 12rpx rgba(0, 0, 0, 0.08);
  gap: 16rpx;
}

.btn {
  flex: 1;
  height: 88rpx;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: bold;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: 1;
}

.btn-primary {
  background: linear-gradient(135deg, #4A90E2 0%, #357ABD 100%);
  color: #fff;
}

.btn-secondary {
  background-color: #fff;
  color: #4A90E2;
  border: 2rpx solid #4A90E2;
}
