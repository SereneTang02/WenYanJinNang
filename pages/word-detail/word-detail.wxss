/* pages/word-detail/word-detail.wxss - 温润古典·书卷风 */
page {
  background: #FBF6F0;
}

.container {
  min-height: 100vh;
  padding-bottom: 150rpx;
}

/* 顶部区域 */
.hero-header {
  background: linear-gradient(180deg, #E8D5B8 0%, #F2E8D6 60%, #FBF6F0 100%);
  padding: 60rpx 36rpx 48rpx;
  color: #1A1008;
  border-radius: 0 0 48rpx 48rpx;
  position: relative;
  overflow: hidden;
}

.hero-header::after {
  content: '';
  position: absolute;
  top: -60rpx;
  right: -60rpx;
  width: 240rpx;
  height: 240rpx;
  border-radius: 50%;
  background: rgba(200, 168, 124, 0.1);
}

.word-title {
  font-size: 64rpx;
  font-weight: bold;
  color: #1A1008;
  margin-bottom: 12rpx;
}

.pinyin {
  font-size: 28rpx;
  color: #4A3C30;
  margin-bottom: 24rpx;
}

/* 标签区 */
.tags-section {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
}

.tag {
  padding: 10rpx 20rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  margin-right: 12rpx;
  margin-bottom: 8rpx;
  background: rgba(200, 168, 124, 0.12);
  color: #9E6B2C;
  border: 1rpx solid rgba(200, 168, 124, 0.25);
  line-height: 1;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 学习进度卡片 */
.progress-card {
  background: rgba(255, 255, 255, 0.88);
  border: 1rpx solid rgba(200, 175, 140, 0.18);
  border-radius: 24rpx;
  padding: 24rpx;
  margin: -24rpx 24rpx 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(166, 138, 100, 0.08);
  position: relative;
  z-index: 1;
}

.progress-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #1A1008;
  margin-bottom: 20rpx;
}

.progress-stats {
  display: flex;
  justify-content: space-around;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-num {
  font-size: 40rpx;
  font-weight: bold;
  margin-bottom: 6rpx;
}

.stat-num.correct {
  color: #4CAF50;
}

.stat-num.wrong {
  color: #E05A47;
}

.stat-num.rate {
  color: #C4882E;
}

.stat-label {
  font-size: 24rpx;
  color: #5C4D3E;
}

/* 义项列表 */
.meanings-section {
  padding: 0 24rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #1A1008;
  margin-bottom: 20rpx;
}

.meaning-card {
  background: rgba(255, 255, 255, 0.88);
  border: 1rpx solid rgba(200, 175, 140, 0.18);
  border-radius: 24rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(166, 138, 100, 0.08);
}

/* 义项标题 */
.meaning-header {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.meaning-number {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: #C4882E;
  color: #fff;
  font-size: 24rpx;
  font-weight: bold;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 12rpx;
  flex-shrink: 0;
}

.meaning-gloss {
  font-size: 32rpx;
  font-weight: bold;
  color: #1A1008;
  flex: 1;
}

.core-badge {
  padding: 4rpx 12rpx;
  background: #E05A47;
  color: #fff;
  font-size: 22rpx;
  border-radius: 10rpx;
  font-weight: bold;
  flex-shrink: 0;
}

/* 用法说明 */
.usage-note {
  display: flex;
  align-items: flex-start;
  padding: 16rpx;
  background-color: rgba(200, 168, 124, 0.1);
  border-radius: 16rpx;
  margin-bottom: 16rpx;
}

.note-icon {
  font-size: 28rpx;
  margin-right: 8rpx;
  flex-shrink: 0;
}

.note-text {
  font-size: 26rpx;
  color: #1A1008;
  flex: 1;
  line-height: 1.6;
}

/* 例句列表 */
.examples-list {
  margin-top: 12rpx;
}

.example-card {
  padding: 16rpx;
  background-color: #F5F0E8;
  margin-bottom: 12rpx;
  border-radius: 16rpx;
}

.example-card:last-child {
  margin-bottom: 0;
}

.example-text {
  display: block;
  font-size: 28rpx;
  color: #1A1008;
  line-height: 1.8;
  margin-bottom: 10rpx;
}

.example-meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.example-source {
  font-size: 24rpx;
  color: #9E6B2C;
  padding: 4rpx 12rpx;
  background-color: rgba(200, 168, 124, 0.12);
  border-radius: 10rpx;
}

.example-grade {
  font-size: 22rpx;
  color: #fff;
  padding: 4rpx 12rpx;
  background: #4CAF50;
  border-radius: 10rpx;
}

/* 底部操作按钮 */
.action-buttons {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  padding: 20rpx 24rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background-color: rgba(255, 255, 255, 0.95);
  box-shadow: 0 -4rpx 16rpx rgba(166, 138, 100, 0.08);
  gap: 16rpx;
}

.btn {
  flex: 1;
  height: 88rpx;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: bold;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: 1;
}

.btn-primary {
  background: linear-gradient(135deg, #C4882E, #A56A1F);
  color: #FFFDF8;
  box-shadow: 0 6rpx 20rpx rgba(200, 168, 124, 0.3);
}

.btn-secondary {
  background-color: rgba(255, 255, 255, 0.88);
  color: #9E6B2C;
  border: 2rpx solid #C9B18A;
}
