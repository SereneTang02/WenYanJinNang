<!--pages/word-detail/word-detail.wxml-->
<view class="container">
  <!-- 顶部蓝色区域 -->
  <view class="hero-header">
    <view class="word-title">{{currentWord.word}}</view>
    <view class="pinyin" wx:if="{{currentWord.pinyin}}">{{currentWord.pinyin}}</view>

    <!-- 标签区 -->
    <view class="tags-section">
      <text class="tag" wx:if="{{currentWord.grade}}">{{currentWord.grade}}</text>
      <text class="tag" wx:if="{{currentWord.difficulty}}">{{currentWord.difficulty}}</text>
      <text class="tag" wx:if="{{currentWord.category}}">{{currentWord.category}}</text>
      <text class="tag" wx:for="{{currentWord.displayTags}}" wx:for-item="tag" wx:key="key" wx:if="{{currentWord.displayTags && currentWord.displayTags.length > 0}}">{{tag.label}}</text>
    </view>
  </view>

  <!-- 学习进度卡片 -->
  <view class="progress-card" wx:if="{{progress}}">
    <view class="progress-title">学习进度</view>
    <view class="progress-stats">
      <view class="stat-item">
        <text class="stat-num correct">{{progress.correct}}</text>
        <text class="stat-label">正确</text>
      </view>
      <view class="stat-item">
        <text class="stat-num wrong">{{progress.wrong}}</text>
        <text class="stat-label">错误</text>
      </view>
      <view class="stat-item">
        <text class="stat-num rate">{{progress.rate}}%</text>
        <text class="stat-label">正确率</text>
      </view>
    </view>
  </view>

  <!-- 义项列表 -->
  <view class="meanings-section">
    <view class="section-title">义项详解</view>

    <view
      class="meaning-card"
      wx:for="{{currentWord.meanings}}"
      wx:for-item="meaning"
      wx:key="id"
    >
      <!-- 义项标题 -->
      <view class="meaning-header">
        <view class="meaning-number">{{index + 1}}</view>
        <text class="meaning-gloss">{{meaning.gloss}}</text>
        <text class="core-badge" wx:if="{{meaning.isCore}}">★ 核心</text>
      </view>

      <!-- 用法说明 -->
      <view class="usage-note" wx:if="{{meaning.usageNote}}">
        <text class="note-icon">💡</text>
        <text class="note-text">{{meaning.usageNote}}</text>
      </view>

      <!-- 例句列表 -->
      <view class="examples-list" wx:if="{{meaning.examples && meaning.examples.length > 0}}">
        <view
          class="example-card"
          wx:for="{{meaning.examples}}"
          wx:for-item="example"
          wx:key="*this"
        >
          <text class="example-text">"{{example.text}}"</text>
          <view class="example-meta">
            <text class="example-source" wx:if="{{example.source}}">{{example.source}}</text>
            <text class="example-grade" wx:if="{{example.grade}}">{{example.grade}}</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 底部操作按钮 -->
  <view class="action-buttons">
    <button class="btn btn-primary" bindtap="onStartPractice">
      开始练习
    </button>
    <button class="btn btn-secondary" bindtap="onAddToDaily">
      加入今日任务
    </button>
  </view>
</view>
