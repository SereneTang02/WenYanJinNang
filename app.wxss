/* app.wxss - 温润古典·书卷风 */
page {
  background-color: #FBF6F0;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif;
  color: #1A1008;
  letter-spacing: 2rpx;
}

.container {
  padding: 20rpx;
  box-sizing: border-box;
}

.card {
  background-color: rgba(255, 255, 255, 0.9);
  border-radius: 24rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 16rpx rgba(166, 138, 100, 0.08);
  border: 1rpx solid rgba(200, 175, 140, 0.2);
}

.btn-primary {
  background: linear-gradient(135deg, #C4882E, #A56A1F);
  color: #FFFDF8;
  border-radius: 40rpx;
  padding: 24rpx;
  text-align: center;
  font-size: 32rpx;
  margin: 20rpx 0;
  letter-spacing: 4rpx;
}

.btn-secondary {
  background-color: rgba(255, 255, 255, 0.9);
  color: #9E6B2C;
  border: 2rpx solid #C9B18A;
  border-radius: 40rpx;
  padding: 24rpx;
  text-align: center;
  font-size: 32rpx;
  margin: 20rpx 0;
}

.text-primary {
  color: #9E6B2C;
}

.text-secondary {
  color: #5C4D3E;
  font-size: 28rpx;
}

.text-success {
  color: #4CAF50;
}

.text-error {
  color: #E05A47;
}
