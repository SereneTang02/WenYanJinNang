/* app.wxss */
page {
  background-color: #f8f8f8;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif;
}

.container {
  padding: 20rpx;
  box-sizing: border-box;
}

.card {
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
}

.btn-primary {
  background-color: #4A90E2;
  color: #ffffff;
  border-radius: 8rpx;
  padding: 24rpx;
  text-align: center;
  font-size: 32rpx;
  margin: 20rpx 0;
}

.btn-secondary {
  background-color: #ffffff;
  color: #4A90E2;
  border: 2rpx solid #4A90E2;
  border-radius: 8rpx;
  padding: 24rpx;
  text-align: center;
  font-size: 32rpx;
  margin: 20rpx 0;
}

.text-primary {
  color: #4A90E2;
}

.text-secondary {
  color: #666666;
  font-size: 28rpx;
}

.text-success {
  color: #52C41A;
}

.text-error {
  color: #F5222D;
}
